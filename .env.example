# Recupero environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Required for Phase 1 ---

# Etherscan API v2 (multichain) — free tier, 5 req/sec, 100k req/day
# Get key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# CoinGecko — free "demo" tier works for low volume
# Get key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# --- Optional / future phases ---

# Helius (Solana) — free tier 100 req/sec, 1M credits/month
# Phase 3 requirement
HELIUS_API_KEY=

# Alchemy — alternative / fallback for Ethereum RPC
ALCHEMY_API_KEY=

# --- Phase 2 worker (Railway) ---

# Supabase project URL. e.g. https://abcxyz.supabase.co
SUPABASE_URL=

# Supabase service-role key (bypasses RLS). Settings → API → service_role.
# New-style sb_secret_* keys work; the worker sends both apikey and
# Authorization headers on every Storage REST request internally.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for the worker's claim/heartbeat SQL.
# Settings → Database → Connection string → "URI" tab.
# URL-encode any special characters in the password (% → %25, # → %23).
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL=

# Anthropic API key for the AI editorial drafting stage.
# Get at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Worker tunables (optional; sensible defaults applied if unset)
# RECUPERO_HEARTBEAT_INTERVAL_SEC=30
# RECUPERO_STALE_AFTER_SEC=300
# RECUPERO_POLL_IDLE_SEC=2
# RECUPERO_POLL_MAX_SEC=30

# --- Operational ---

# Where Recupero writes case folders. Defaults to ./data/cases
RECUPERO_DATA_DIR=./data

# Log level: DEBUG, INFO, WARNING, ERROR
RECUPERO_LOG_LEVEL=INFO
