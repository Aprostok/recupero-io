# Recupero environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Required for Phase 1 ---

# Etherscan API v2 (multichain) — free tier, 5 req/sec, 100k req/day
# Get key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# CoinGecko — free "demo" tier works for low volume
# Get key at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# --- Optional / future phases ---

# Helius (Solana) — free tier 100 req/sec, 1M credits/month
# Phase 3 requirement
HELIUS_API_KEY=

# Alchemy — alternative / fallback for Ethereum RPC
ALCHEMY_API_KEY=

# --- Phase 2 worker (Railway) ---

# Supabase project URL. e.g. https://abcxyz.supabase.co
SUPABASE_URL=

# Supabase service-role key (bypasses RLS). Settings → API → service_role.
# New-style sb_secret_* keys work; the worker sends both apikey and
# Authorization headers on every Storage REST request internally.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for the worker's claim/heartbeat SQL.
# Settings → Database → Connection string → "URI" tab.
# URL-encode any special characters in the password (% → %25, # → %23).
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_URL=

# Anthropic API key for the AI editorial drafting stage.
# Get at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# 32-byte secret used to HMAC portal access tokens before they hit the
# database. REQUIRED — without this set, portal token mint raises
# RuntimeError and every verify_token call returns None. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Rotating this value invalidates every existing token; operators
# re-issue from the CLI. S-5 close-out (2026-05-26): the legacy
# raw-token fallback was removed so the pepper is now load-bearing.
RECUPERO_TOKEN_PEPPER=

# Worker tunables (optional; sensible defaults applied if unset)
# RECUPERO_HEARTBEAT_INTERVAL_SEC=30
# RECUPERO_STALE_AFTER_SEC=300
# RECUPERO_POLL_IDLE_SEC=2
# RECUPERO_POLL_MAX_SEC=30

# Investigator identity (optional; defaults to Alec Prostok / Recupero LLC).
# Override per-deployment when a different operator is responsible for the
# briefs. These values appear on every freeze-request letter and LE handoff
# the worker generates, and on the editorial signature line.
# RECUPERO_INVESTIGATOR_NAME=Alec Prostok
# RECUPERO_INVESTIGATOR_EMAIL=alec@recupero.io
# RECUPERO_INVESTIGATOR_ENTITY=Recupero LLC
# RECUPERO_INVESTIGATOR_ENTITY_FULL=Recupero LLC, a Delaware limited liability company
# RECUPERO_INVESTIGATOR_WEB=recupero.io
# RECUPERO_INVESTIGATOR_PHONE=

# --- Customer portal + Stripe (Phase 5/6) ---

# Canonical portal hostname. Used to build customer-facing URLs
# like https://portal.recupero.io/portal/<token>. If unset, the
# worker falls back to RAILWAY_PUBLIC_DOMAIN (auto-populated on
# Railway deploys) so the portal works end-to-end even before
# DNS is configured for a custom subdomain.
RECUPERO_PORTAL_BASE_URL=

# Resend (transactional email). Get key at https://resend.com.
# Required for the auto-send of victim_summary + the weekly
# follow-up cron.
RESEND_API_KEY=

# Stripe webhook signing secret. Settings → Webhooks → endpoint
# → Reveal. Required to verify the HMAC signature on
# /webhooks/stripe POSTs. Without this set the endpoint returns
# 503 (Stripe will retry; configure it before going live).
STRIPE_WEBHOOK_SECRET=

# Stripe Payment Link URLs. Set these to the base URLs from your
# Stripe Dashboard's Payment Links section (e.g.,
# https://buy.stripe.com/test_xyz). The CLI's
# `recupero-ops generate-payment-link` reads these and appends
# the per-customer client_reference_id at link-mint time.
# Two separate links — one $499 diagnostic, one $1,500 engagement.
RECUPERO_STRIPE_DIAGNOSTIC_PAYMENT_LINK=
RECUPERO_STRIPE_ENGAGEMENT_PAYMENT_LINK=

# Email address that receives operator alerts when Stripe events
# need attention — refunds (charge.refunded) and disputes
# (charge.dispute.created). If unset, alerts fall back to
# RECUPERO_EMAIL_FROM. Defaults to alec@recupero.io if neither
# is set. Set this when the operator inbox is different from
# the From address.
RECUPERO_OPS_ALERT_EMAIL=

# --- Operational ---

# Where Recupero writes case folders. Defaults to ./data/cases
RECUPERO_DATA_DIR=./data

# Log level: DEBUG, INFO, WARNING, ERROR
RECUPERO_LOG_LEVEL=INFO
