<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{% block title %}Recupero{% endblock %} — Recupero</title>
    <style>
        /* Inlined to keep the portal self-contained (no asset
           pipeline, no Railway static-file routing). Keep it
           short — this whole template renders in < 5kb. */
        :root {
            --fg: #1a1a1a;
            --fg-muted: #555;
            --bg: #fafaf7;
            --card-bg: #ffffff;
            --border: #e3e1da;
            --accent: #2a5e3e;       /* deep green — "trust" */
            --accent-hover: #1e4a30;
            --warn: #9a5c00;          /* amber for expired/inactive */
            --danger: #9a2a2a;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                         Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.5;
        }
        .container {
            max-width: 720px;
            margin: 0 auto;
            padding: 32px 24px 64px;
        }
        /* Wide variant — used by the fund-flow map page where the
           graph canvas needs the full viewport width. */
        .container.wide { max-width: 1100px; }
        .brand {
            font-weight: 700;
            font-size: 18px;
            letter-spacing: -0.01em;
            margin-bottom: 24px;
            color: var(--accent);
        }
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 28px;
            margin-bottom: 20px;
        }
        h1 {
            font-size: 22px;
            margin: 0 0 8px;
            letter-spacing: -0.01em;
        }
        h2 {
            font-size: 16px;
            margin: 28px 0 12px;
            letter-spacing: -0.005em;
            text-transform: uppercase;
            color: var(--fg-muted);
            font-weight: 600;
            font-size: 12px;
            letter-spacing: 0.05em;
        }
        .case-meta {
            color: var(--fg-muted);
            font-size: 14px;
        }
        .case-meta code {
            background: #f0eee6;
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 12px;
        }
        .row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }
        .row:last-child { border-bottom: 0; }
        .row .k { color: var(--fg-muted); }
        .row .v { font-weight: 500; text-align: right; }
        .pill {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .pill.ok    { background: #dff0e2; color: var(--accent); }
        .pill.warn  { background: #fbe9c8; color: var(--warn); }
        .pill.muted { background: #ecebe4; color: var(--fg-muted); }
        .pill.danger{ background: #f4d3d3; color: var(--danger); }
        .btn {
            display: inline-block;
            background: var(--accent);
            color: #fff;
            text-decoration: none;
            padding: 10px 18px;
            border-radius: 5px;
            font-weight: 600;
            font-size: 14px;
            border: 0;
            cursor: pointer;
        }
        .btn:hover { background: var(--accent-hover); }
        .btn[disabled] { background: #b9b9b3; cursor: not-allowed; }
        .btn.secondary {
            background: transparent;
            color: var(--accent);
            border: 1px solid var(--accent);
        }
        ul.artifacts {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        ul.artifacts li {
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        ul.artifacts li:last-child { border-bottom: 0; }
        ul.artifacts .name { font-weight: 500; font-size: 14px; }
        ul.artifacts .meta { font-size: 12px; color: var(--fg-muted); }
        form.sign-form label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
            font-size: 14px;
        }
        form.sign-form input[type=text] {
            width: 100%;
            padding: 10px 12px;
            font-size: 16px;
            border: 1px solid var(--border);
            border-radius: 4px;
            margin-bottom: 16px;
        }
        form.sign-form .agreement {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            padding: 14px;
            background: #f7f5ed;
            border-radius: 5px;
            margin-bottom: 18px;
            font-size: 14px;
        }
        form.sign-form .agreement input { margin-top: 2px; }
        .footer {
            font-size: 12px;
            color: var(--fg-muted);
            margin-top: 40px;
            text-align: center;
        }
        .footer a { color: var(--fg-muted); }
        .empty {
            color: var(--fg-muted);
            font-style: italic;
            font-size: 14px;
        }
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body>
<div class="container {% block container_extra %}{% endblock %}">
    <div class="brand">Recupero</div>
    {% block content %}{% endblock %}
    <div class="footer">
        Recupero · crypto recovery service ·
        <a href="mailto:support@recupero.io">support@recupero.io</a>
    </div>
</div>
</body>
</html>
