    fasset.addEventListener("change", () => { asset = fasset.value; applyFilters(); saveState(); });

    const trng = DATA.meta.timeRange;
    if (trng && trng.min && trng.max && trng.min !== trng.max) {
      const scrub = document.getElementById("scrubber"); scrub.hidden = false;
      const d0 = new Date(trng.min + "T00:00:00Z").getTime(), d1 = new Date(trng.max + "T00:00:00Z").getTime();
      document.getElementById("tl-from").textContent = trng.min;
      const slider = document.getElementById("tl-range"), toLab = document.getElementById("tl-to"); toLab.textContent = trng.max;
      const setFrom = () => { const f = slider.value / 100; const iso = new Date(d0 + f * (d1 - d0)).toISOString().slice(0, 10); timeCutoff = (+slider.value >= 100) ? null : iso; toLab.textContent = iso; applyFilters(); };
      slider.addEventListener("input", setFrom);
      let playing = null; const pb = document.getElementById("tl-play");
      pb.onclick = () => { if (playing) { clearInterval(playing); playing = null; pb.textContent = "▶ Play"; return; } if (+slider.value >= 100) slider.value = 0; pb.textContent = "❚❚ Pause"; playing = setInterval(() => { slider.value = Math.min(100, +slider.value + 2); setFrom(); if (+slider.value >= 100) { clearInterval(playing); playing = null; pb.textContent = "▶ Play"; } }, 120); };
    }

    function fit() {
      if (!view.nodes.length) return;
      let a = Infinity, b = Infinity, c = -Infinity, d = -Infinity;
      for (const n of view.nodes) { const p = pos.get(n.id); a = Math.min(a, p.x); b = Math.min(b, p.y); c = Math.max(c, p.x); d = Math.max(d, p.y); }
      const bw = (c - a) || 1, bh = (d - b) || 1, pad = 70;
      scale = Math.max(.2, Math.min(2, Math.min((W - pad) / bw, (H - pad) / bh)));
      tx = W / 2 - ((a + c) / 2) * scale; ty = H / 2 - ((b + d) / 2) * scale; applyT();
    }
    window.addEventListener("resize", () => { W = svg.clientWidth || W; computeRadial(view); });

    // boot — reflect restored layout on the segmented control
    for (const [id, key] of [["lay-force", "force"], ["lay-flow", "flow"], ["lay-radial", "radial"]]) document.getElementById(id).classList.toggle("on", key === layout);
    rebuild(false); loop(); setTimeout(fit, 1400);
  })();
  </script>

{% endif %}
{% endblock %}
