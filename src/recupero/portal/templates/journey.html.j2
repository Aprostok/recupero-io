{% extends "_base.html.j2" %}
{% block title %}Fund-flow map · {{ case.case_number }}{% endblock %}
{% block container_extra %}wide{% endblock %}
{% block head_extra %}
<style>
  .map-head { display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; }
  .map-head .back { font-size:13px; }
  .summary-line { font-size:15px; margin:6px 0 0; }
  .breakdown { list-style:none; padding:0; margin:6px 0 0; }
  .breakdown li { padding:9px 0; border-bottom:1px solid var(--border); }
  .breakdown li:last-child { border-bottom:0; }
  .bd-top { display:flex; justify-content:space-between; align-items:center; gap:12px; }
  .bd-name { display:flex; align-items:center; gap:8px; font-weight:600; font-size:14px; }
  .bd-dot { width:11px; height:11px; border-radius:50%; flex:0 0 auto; }
  .bd-usd { font-variant-numeric:tabular-nums; font-weight:600; font-size:14px; }
  .bd-bar { height:6px; border-radius:3px; margin-top:6px; background:#eee; overflow:hidden; }
  .bd-bar > span { display:block; height:100%; border-radius:3px; }
  .bd-blurb { color:var(--fg-muted); font-size:12.5px; margin-top:5px; }
  .timeline { list-style:none; padding:0; margin:0; }
  .timeline li { display:flex; gap:10px; padding:6px 0; font-size:13.5px; }
  .timeline .tl-when { color:var(--fg-muted); min-width:130px; font-variant-numeric:tabular-nums; }
  .graph-card { padding:0; overflow:hidden; }
  .bar { display:flex; gap:8px; align-items:center; flex-wrap:wrap; padding:10px 14px; border-bottom:1px solid var(--border); }
  .bar.filters { background:#faf9f4; }
  .bar label { font-size:12px; color:var(--fg-muted); display:flex; gap:6px; align-items:center; }
  .bar input[type=text] { flex:1 1 180px; min-width:150px; padding:8px 10px; border:1px solid var(--border); border-radius:5px; font-size:13px; }
  .bar select { padding:6px 8px; border:1px solid var(--border); border-radius:5px; font-size:13px; background:#fff; }
  .btn-sm { background:#fff; border:1px solid var(--border); border-radius:5px; padding:7px 11px; font-size:13px; cursor:pointer; color:var(--fg); }
  .btn-sm:hover { background:#f1efe7; }
  .btn-sm.on { background:var(--accent); color:#fff; border-color:var(--accent); }
  .seg { display:inline-flex; border:1px solid var(--border); border-radius:5px; overflow:hidden; }
  .seg button { border:0; background:#fff; padding:7px 11px; font-size:13px; cursor:pointer; color:var(--fg); }
  .seg button.on { background:var(--accent); color:#fff; }
  .spacer { margin-left:auto; }
  #legend { display:flex; gap:8px; flex-wrap:wrap; padding:9px 14px; border-bottom:1px solid var(--border); }
  #legend .lg { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--fg); cursor:pointer; border:1px solid transparent; border-radius:999px; padding:2px 8px; user-select:none; }
  #legend .lg:hover { background:#f1efe7; }
  #legend .lg.off { opacity:.4; text-decoration:line-through; }
  #legend .lg-dot { width:11px; height:11px; border-radius:50%; }
  #scrubber { display:flex; gap:10px; align-items:center; padding:9px 14px; border-bottom:1px solid var(--border); font-size:12px; color:var(--fg-muted); }
  #scrubber input[type=range] { flex:1; }
  #graph-wrap { position:relative; }
  svg#map { width:100%; height:600px; display:block; background:#fbfbf9; cursor:grab; touch-action:none; }
  svg#map:active { cursor:grabbing; }
  .edge { fill:none; }
  .edge.cross { stroke-dasharray:5 4; }
  .edge.dim { opacity:.10; }
  .edge.hot { stroke:#2a5e3e !important; }
  .edge.path { stroke:#1D4ED8 !important; stroke-opacity:1; }
  .edge.hidden { display:none; }
  .node { cursor:pointer; }
  .node circle { stroke-width:2.5; }
  .node.dim { opacity:.16; }
  .node.faded { opacity:.30; }
  .node.sel circle, .node.path circle { stroke:#1D4ED8; stroke-width:4; }
  .node.pick circle { stroke:#9a5c00; stroke-width:4; }
  .node text { font-size:11px; fill:var(--fg); pointer-events:none; }
  .node .count { font-size:10px; font-weight:700; fill:#fff; pointer-events:none; }
  .node.origin circle { stroke-width:3.5; }
  #tip { position:absolute; pointer-events:none; opacity:0; transition:opacity .1s; background:#1f2430; color:#f3f4f6; border-radius:7px; padding:9px 11px; font-size:12px; line-height:1.4; max-width:280px; box-shadow:0 6px 22px rgba(0,0,0,.3); z-index:60; }
  #tip .tt-title { font-weight:700; margin-bottom:3px; }
  #tip .tt-sub { color:#aab2c0; font-size:11px; margin-bottom:5px; }
  #tip .tt-row { display:flex; justify-content:space-between; gap:14px; }
  #panel { position:absolute; top:10px; right:10px; width:288px; max-height:calc(100% - 20px); overflow:auto; background:#fff; border:1px solid var(--border); border-radius:8px; box-shadow:0 8px 28px rgba(0,0,0,.12); padding:14px 15px; font-size:13px; display:none; z-index:50; }
  #panel.show { display:block; }
  #panel .p-close { float:right; cursor:pointer; color:var(--fg-muted); font-size:16px; line-height:1; border:0; background:none; }
  #panel .p-chip { display:inline-block; color:#fff; font-size:11px; font-weight:600; padding:2px 9px; border-radius:999px; margin:2px 0 8px; }
  #panel h3 { margin:0 6px 2px 0; font-size:15px; }
  #panel .p-addr { font-family:ui-monospace,monospace; font-size:11px; color:var(--fg-muted); word-break:break-all; margin-bottom:8px; }
  #panel .p-row { display:flex; justify-content:space-between; gap:12px; padding:4px 0; border-bottom:1px solid var(--border); }
  #panel .p-row:last-of-type { border-bottom:0; }
  #panel .p-row .k { color:var(--fg-muted); } #panel .p-row .v { font-weight:600; font-variant-numeric:tabular-nums; }
  #panel .donuts { display:flex; gap:6px; justify-content:space-around; margin:8px 0 4px; }
  #panel .donut-wrap { text-align:center; } #panel .donut-cap { font-size:11px; color:var(--fg-muted); margin-top:2px; }
  #panel .p-act { margin-top:10px; }
  #panel .p-members, #panel .p-tx { margin:8px 0 0; padding:0; list-style:none; max-height:170px; overflow:auto; }
  #panel .p-members li { font-family:ui-monospace,monospace; font-size:11px; padding:3px 0; border-bottom:1px dashed var(--border); }
  #panel .p-tx li { display:flex; justify-content:space-between; gap:8px; font-size:12px; padding:4px 0; border-bottom:1px dashed var(--border); }
  #panel .p-tx .tx-d { color:var(--fg-muted); font-variant-numeric:tabular-nums; }
  #panel a { color:var(--accent); }
  #mini { position:absolute; bottom:10px; left:10px; width:168px; height:108px; background:rgba(255,255,255,.92); border:1px solid var(--border); border-radius:6px; z-index:40; cursor:pointer; }
  #mini .mini-vp { fill:rgba(42,94,62,.12); stroke:var(--accent); stroke-width:1; }
  .map-note { font-size:12px; color:var(--fg-muted); margin-top:10px; }
  .hint { font-size:12px; color:var(--fg-muted); padding:0 14px 10px; }
  @media print {
    .bar, #scrubber, #legend, #tip, #panel, #mini, .hint, .map-head .back, .footer { display:none !important; }
    svg#map { height:520px; }
  }
</style>
{% endblock %}
{% block content %}

<div class="card">
  <div class="map-head">
    <h1>Your fund-flow map</h1>
    <span class="case-meta">Case <code>{{ case.case_number }}</code></span>
    <a class="back" href="/portal/{{ token }}">← Back to case</a>
  </div>
  {% if journey and journey.meta.summaryLine %}
    <p class="summary-line">{{ journey.meta.summaryLine }}</p>
  {% endif %}
  <p class="case-meta" style="margin-top:6px;">
    A simplified view of where your funds travelled, built from the same
    analysis behind your diagnostic. Open groups, switch layouts, filter
    by time or value, and click any point to see its details.
  </p>
</div>

{% if not journey %}
  <div class="card">
    <p class="empty">Your fund-flow map will appear here once your
    diagnostic finishes processing — usually within a few hours of
    intake. If it's been longer, reply to your intake email and we'll
    take a look.</p>
  </div>
{% else %}

  {% if journey.statusTotals %}
  <h2>Where your funds are</h2>
  <div class="card">
    <ul class="breakdown">
      {% set maxusd = journey.statusTotals|map(attribute='usd')|max %}
      {% for s in journey.statusTotals %}
        <li>
          <div class="bd-top">
            <span class="bd-name">
              <span class="bd-dot" style="background:{{ s.color }};"></span>
              {{ s.label }}
              <span class="case-meta">· {{ s.count }} endpoint{{ '' if s.count == 1 else 's' }}</span>
            </span>
            <span class="bd-usd">{{ s.usdLabel }}</span>
          </div>
          <div class="bd-bar">
            <span style="background:{{ s.color }}; width:{{ (100.0 * s.usd / maxusd)|round(1) if maxusd and maxusd > 0 else 0 }}%;"></span>
          </div>
          <div class="bd-blurb">{{ s.blurb }}</div>
        </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {% if activity %}
  <h2>Case activity</h2>
  <div class="card">
    <ul class="timeline">
      {% for a in activity %}
        <li><span class="tl-when">{{ a.when }}</span><span>{{ a.label }}</span></li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <h2>Interactive map</h2>
  <div class="card graph-card">
    <div class="bar">
      <input type="text" id="search" placeholder="Search a point or label…" autocomplete="off">
      <span class="seg" role="group" aria-label="Layout">
        <button type="button" id="lay-force" class="on">Force</button>
        <button type="button" id="lay-flow">Flow</button>
        <button type="button" id="lay-radial">Radial</button>
      </span>
      <button type="button" class="btn-sm" id="btn-path">Find path</button>
      <button type="button" class="btn-sm" id="btn-expand">Open all groups</button>
      <button type="button" class="btn-sm" id="btn-collapse">Close all groups</button>
      <span class="spacer"></span>
      <button type="button" class="btn-sm" id="btn-fit">Fit</button>
      <button type="button" class="btn-sm" id="btn-reset">Reset</button>
      <button type="button" class="btn-sm" id="btn-png">PNG</button>
      <button type="button" class="btn-sm" id="btn-csv">CSV</button>
      <button type="button" class="btn-sm" id="btn-print">Print / PDF</button>
    </div>
    <div class="bar filters">
      <label>Min value
        <input type="range" id="f-min" min="0" max="100" value="0">
        <span id="f-min-lab" style="min-width:70px;">$0</span>
      </label>
      <label>Asset
        <select id="f-asset"><option value="">All assets</option></select>
      </label>
    </div>
    <div id="scrubber" hidden>
      <button type="button" class="btn-sm" id="tl-play">▶ Play</button>
      <span id="tl-from"></span>
      <input type="range" id="tl-range" min="0" max="100" value="100">
      <span id="tl-to"></span>
    </div>
    <div id="legend"></div>
    <p class="hint" id="path-hint" hidden>Path mode: click your start point, then your end point.</p>
    <div id="graph-wrap">
      <svg id="map" role="img" aria-label="Interactive fund-flow map" data-viewkey="{{ case.case_number }}"></svg>
      <svg id="mini" aria-hidden="true"></svg>
      <div id="tip"></div>
      <div id="panel" aria-live="polite"></div>
    </div>
  </div>
  <p class="map-note">
    Addresses and labels shown here are derived from public blockchain
    data and our analysis. This map is a guide to your case, not a legal
    determination of recoverability.
    {% if journey.meta.truncated %}
      For clarity, {{ journey.meta.hiddenNodeCount }} lower-value
      pass-through wallet{{ '' if journey.meta.hiddenNodeCount == 1 else 's' }}
      {{ 'is' if journey.meta.hiddenNodeCount == 1 else 'are' }} not shown.
    {% endif %}
  </p>

  <script id="journey-data" type="application/json">{{ journey_json|safe }}</script>
  <script nonce="{{ nonce }}">
  "use strict";
  (function () {
    const DATA = JSON.parse(document.getElementById("journey-data").textContent);
    const NS = "http://www.w3.org/2000/svg";
    const svg = document.getElementById("map");
    const mini = document.getElementById("mini");
    const tip = document.getElementById("tip");
    const panel = document.getElementById("panel");

    const nodeById = new Map(DATA.nodes.map(n => [n.id, n]));
    const clusterById = new Map((DATA.clusters || []).map(c => [c.id, c]));
    const usdNum = s => parseFloat(String(s || "0").replace(/[$,]/g, "")) || 0;
    const fmtUsd = v => "$" + Number(v).toLocaleString(undefined, { maximumFractionDigits: 2 });
    const EDGE_COL = "#c4c0b4", EDGE_CROSS = "#C2410C";

    // status -> {label,color}
    const STATUS = {};
    for (const n of DATA.nodes) STATUS[n.status] = { label: n.statusLabel, color: n.statusColor };
    for (const c of (DATA.clusters || [])) STATUS[c.status] = { label: c.statusLabel, color: c.statusColor };
    const statusColor = st => (STATUS[st] && STATUS[st].color) || "#94A3B8";
    const statusLabel = st => (STATUS[st] && STATUS[st].label) || st;

    // ---- persisted state ----
    const VK = "recupero.map." + (svg.dataset.viewkey || "case");
    const expanded = new Set(), statusOff = new Set();
    let minUsd = 0, asset = "", timeCutoff = null;
    let layout = "force";            // force | flow | radial
    let pathMode = false, pickA = null;
    const pathNodes = new Set(), pathEdges = new Set();
    let selected = null, isolated = null;
    (function loadState() {
      try {
        const s = JSON.parse(localStorage.getItem(VK) || "null"); if (!s) return;
        if (["force", "flow", "radial"].includes(s.layout)) layout = s.layout;
        (s.expanded || []).forEach(c => expanded.add(c));
        (s.statusOff || []).forEach(x => statusOff.add(x));
        minUsd = +s.minUsd || 0; asset = s.asset || "";
      } catch (e) { /* ignore */ }
    })();
    function saveState() {
      try { localStorage.setItem(VK, JSON.stringify({ layout, expanded: [...expanded], statusOff: [...statusOff], minUsd, asset })); } catch (e) { /* ignore */ }
    }

    const maxEdgeUsd = Math.max(1, ...DATA.edges.map(e => e.totalUsdNumeric || 0));
    const maxDepth = (DATA.meta && DATA.meta.maxDepth) || 1;

    // ---- view build (collapse + status filter) ----
    function buildView() {
      const idOf = new Map(), vnodes = [], seen = new Set();
      for (const n of DATA.nodes) {
        const cid = n.clusterId;
        if (cid && clusterById.has(cid) && !expanded.has(cid)) {
          const c = clusterById.get(cid);
          if (statusOff.has(c.status)) { idOf.set(n.id, null); continue; }
          idOf.set(n.id, cid);
          if (!seen.has(cid)) {
            seen.add(cid);
            vnodes.push({ id: cid, kind: "cluster", label: c.label, status: c.status, statusLabel: c.statusLabel,
              color: c.statusColor, size: c.size, memberIds: c.memberIds || [], depth: clusterDepth(c),
              inboundUsd: c.inboundUsd, outboundUsd: c.outboundUsd, total: usdNum(c.inboundUsd) + usdNum(c.outboundUsd),
              inByCategory: aggCat(c.memberIds, "inByCategory"), outByCategory: aggCat(c.memberIds, "outByCategory") });
          }
        } else {
          if (statusOff.has(n.status)) { idOf.set(n.id, null); continue; }
          idOf.set(n.id, n.id);
          vnodes.push({ id: n.id, kind: "node", label: n.label, short: n.short, status: n.status, statusLabel: n.statusLabel,
            color: n.statusColor, chain: n.chain, chainColor: n.chainColor, inboundUsd: n.inboundUsd, outboundUsd: n.outboundUsd,
            explorerUrl: n.explorerUrl, clusterId: n.clusterId, depth: n.depth || 0, total: usdNum(n.inboundUsd) + usdNum(n.outboundUsd),
            inByCategory: n.inByCategory || {}, outByCategory: n.outByCategory || {} });
        }
      }
      const agg = new Map();
      for (const e of DATA.edges) {
        const s = idOf.get(e.source), t = idOf.get(e.target);
        if (!s || !t || s === t) continue;
        const k = s + "␟" + t;
        let a = agg.get(k);
        if (!a) { a = { id: k, source: s, target: t, usd: 0, count: 0, cross: false, assets: new Set(), first: null, last: null, transfers: [], txMore: 0 }; agg.set(k, a); }
        a.usd += e.totalUsdNumeric || 0; a.count += e.transferCount || 0; a.cross = a.cross || !!e.isCrossChain;
        if (e.dominantSymbol) a.assets.add(e.dominantSymbol);
        if (e.firstTime && (!a.first || e.firstTime < a.first)) a.first = e.firstTime;
        if (e.lastTime && (!a.last || e.lastTime > a.last)) a.last = e.lastTime;
        for (const tx of (e.transfers || [])) a.transfers.push(tx);
        a.txMore += e.txMore || 0;
      }
      for (const a of agg.values()) { a.transfers.sort((x, y) => (y.usd || 0) - (x.usd || 0)); if (a.transfers.length > 14) { a.txMore += a.transfers.length - 14; a.transfers = a.transfers.slice(0, 14); } }
      return { nodes: vnodes, edges: [...agg.values()] };
    }
    function clusterDepth(c) { let d = Infinity; for (const m of (c.memberIds || [])) { const n = nodeById.get(m); if (n && (n.depth || 0) < d) d = n.depth || 0; } return d === Infinity ? 0 : d; }
    function aggCat(ids, field) { const out = {}; for (const m of (ids || [])) { const n = nodeById.get(m); if (!n) continue; for (const [k, v] of Object.entries(n[field] || {})) out[k] = (out[k] || 0) + v; } return out; }

    // ---- positions + layout ----
    const pos = new Map();
    let W = svg.clientWidth || 900, H = 600;
    const radialTarget = new Map();
    function computeRadial(view) {
      radialTarget.clear();
      const byD = new Map();
      for (const n of view.nodes) { if (!byD.has(n.depth)) byD.set(n.depth, []); byD.get(n.depth).push(n); }
      const cx = W / 2, cy = H / 2;
      for (const [d, arr] of byD) {
        const r = d === 0 ? 0 : 90 + d * 110;
        arr.forEach((n, i) => { const ang = (i / arr.length) * 2 * Math.PI - Math.PI / 2; radialTarget.set(n.id, { x: cx + r * Math.cos(ang), y: cy + r * Math.sin(ang) }); });
      }
    }
    function seedPositions(view) {
      const cx = W / 2, cy = H / 2;
      for (const n of view.nodes) {
        if (pos.has(n.id)) continue;
        let sx = cx + (Math.random() - .5) * W * .6, sy = cy + (Math.random() - .5) * H * .6;
        if (n.kind === "node" && n.clusterId && pos.has(n.clusterId)) { const p = pos.get(n.clusterId); sx = p.x + (Math.random() - .5) * 40; sy = p.y + (Math.random() - .5) * 40; }
        if (n.status === "origin") { sx = layout === "flow" ? 80 : cx; sy = cy; }
        pos.set(n.id, { x: sx, y: sy, vx: 0, vy: 0 });
      }
    }
    let view = buildView(), alpha = 1;
    const radius = n => Math.max(9, Math.min(30, 9 + Math.log10(n.total + 1) * 2.4)) + (n.kind === "cluster" ? 4 : 0);

    function step() {
      const N = view.nodes, E = view.edges, damp = .9;
      for (let i = 0; i < N.length; i++) {
        const a = pos.get(N[i].id);
        for (let j = i + 1; j < N.length; j++) {
          const b = pos.get(N[j].id);
          let dx = a.x - b.x, dy = a.y - b.y, d2 = dx * dx + dy * dy;
          if (d2 < 1) { d2 = 1; dx = Math.random(); dy = Math.random(); }
          const rep = 5200 / d2 * alpha, d = Math.sqrt(d2), ux = dx / d, uy = dy / d;
          a.vx += ux * rep; a.vy += uy * rep; b.vx -= ux * rep; b.vy -= uy * rep;
        }
      }
      for (const e of E) {
        const a = pos.get(e.source), b = pos.get(e.target); if (!a || !b) continue;
        let dx = b.x - a.x, dy = b.y - a.y; const d = Math.sqrt(dx * dx + dy * dy) || 1;
        const tgt = 90 + Math.log10((e.usd || 0) + 1) * 9, f = (d - tgt) * .02 * alpha, ux = dx / d, uy = dy / d;
        a.vx += ux * f; a.vy += uy * f; b.vx -= ux * f; b.vy -= uy * f;
      }
      const cx = W / 2, cy = H / 2, colW = (W - 140) / Math.max(1, maxDepth);
      for (const n of N) {
        const p = pos.get(n.id);
        if (layout === "flow") { const tx = 80 + (n.depth || 0) * colW; p.vx += (tx - p.x) * .12 * Math.max(alpha, .25); p.vy += (cy - p.y) * .01 * alpha; }
        else if (layout === "radial") { const t = radialTarget.get(n.id); if (t) { p.vx += (t.x - p.x) * .10 * Math.max(alpha, .25); p.vy += (t.y - p.y) * .10 * Math.max(alpha, .25); } }
        else { p.vx += (cx - p.x) * .006 * alpha; p.vy += (cy - p.y) * .006 * alpha; }
        if (p.fx != null) { p.x = p.fx; p.y = p.fy; p.vx = 0; p.vy = 0; continue; }
        p.vx *= damp; p.vy *= damp; p.x += Math.max(-30, Math.min(30, p.vx)); p.y += Math.max(-30, Math.min(30, p.vy));
      }
      alpha *= .985; if (alpha < .02) alpha = .02;
    }

    // ---- DOM ----
    const root = document.createElementNS(NS, "g"); svg.appendChild(root);
    const gE = document.createElementNS(NS, "g"); root.appendChild(gE);
    const gN = document.createElementNS(NS, "g"); root.appendChild(gN);
    let edgeEls = [], nodeEls = [];

    function render() {
      gE.replaceChildren(); gN.replaceChildren(); edgeEls = []; nodeEls = [];
      for (const e of view.edges) {
        const ln = document.createElementNS(NS, "line");
        ln.setAttribute("class", "edge" + (e.cross ? " cross" : ""));
        ln.setAttribute("stroke", e.cross ? EDGE_CROSS : EDGE_COL);
        ln.setAttribute("stroke-width", String(Math.max(1, Math.min(7, Math.log10((e.usd || 0) + 1) * .9))));
        ln.__e = e;
        ln.addEventListener("mouseenter", ev => edgeTip(ev, e));
        ln.addEventListener("mouseleave", hideTip);
        ln.addEventListener("click", ev => { ev.stopPropagation(); selectEdge(e); });
        gE.appendChild(ln); edgeEls.push(ln);
      }
      for (const n of view.nodes) {
        const g = document.createElementNS(NS, "g");
        g.setAttribute("class", "node " + n.status);
        const c = document.createElementNS(NS, "circle");
