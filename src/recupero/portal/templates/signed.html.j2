{% extends "_base.html.j2" %}
{% block title %}Engagement signed — {{ case.case_number }}{% endblock %}
{% block content %}

<div class="card">
    <h1>You're engaged.</h1>
    <p class="case-meta">
        Case <code>{{ case.case_number }}</code> · {{ case.client_name }}
    </p>

    <p style="margin-top: 20px;">
        Signed by <strong>{{ signature.signature_name }}</strong>
        at {{ signature.signed_at }} for
        ${{ "{:,.0f}".format(signature.fee_usd) }}.
    </p>

    <p>You'll get a confirmation email at
        {{ case.client_email or 'your contact email on file' }}
        within a few minutes. Then the active-recovery phase begins:</p>

    <ul style="padding-left: 20px;">
        <li>We send compliance freeze requests to every applicable
            issuer in the next business day.</li>
        <li>Weekly status emails start in 6 days.</li>
        <li>You can return to this page any time to see progress and
            download artifacts.</li>
    </ul>

    <p style="margin-top: 24px;">
        <a class="btn" href="/portal/{{ token }}">Return to case page →</a>
    </p>
</div>

{% endblock %}
