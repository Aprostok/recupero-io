{# Premium document styles — shared by issuer freeze requests and LE handoffs. #}
{# Design language: restrained navy + gold, confident type hierarchy,        #}
{# generous whitespace. Inspired by high-end legal / security firm output.   #}
<style>
  /* ===================================================================
     Design tokens — palette, type, spacing
     =================================================================== */
  :root {
    /* Restrained palette — black ink, warm gray, single thin gold rule. */
    --ink:               #0A0A0A;   /* primary text */
    --ink-soft:          #1F2937;   /* heavier body */
    --ink-muted:         #4B5563;   /* secondary body */
    --ink-quiet:         #6B7280;   /* tertiary / metadata labels */
    --ink-faint:         #9CA3AF;   /* dividers / least-important */
    --rule:              #111827;   /* thin black accent rule */
    --rule-soft:         #D1D5DB;   /* table borders / subtle dividers */
    --gold-accent:       #9C7E3F;   /* single accent stroke; never a chip */

    /* Page surfaces */
    --paper:             #FFFFFF;
    --paper-tint:        #FAFAF7;   /* table zebra / very subtle bg */

    /* Semantic — used sparingly */
    --confidential:      #6B0F0F;   /* italic word, no fill */
    --urgent-bg:         #FBF7E9;
    --urgent-border:     #9C7E3F;
    --action-bg:         #F4F8F4;
    --action-border:     #2F6B3E;
    --color-victim-tint: #EFF4FB;
    --color-perp-tint:   #FBEFEF;

    /* Chain-coded colors — mirror worker/_flow_diagram.py's
       _CHAIN_STROKE table so the address links in body prose pick
       up the same brand color as their corresponding nodes in the
       Appendix A flow diagram. */
    --chain-eth:         #1D4ED8;   /* ethereum / L2s default */
    --chain-arb:         #28A0F0;
    --chain-base:        #0052FF;
    --chain-polygon:     #8247E5;
    --chain-bsc:         #B68A0E;   /* darker than #F0B90B for AA contrast */
    --chain-solana:      #6F33C9;   /* darker than #9945FF for AA contrast */

    /* Type — serif for titles (Georgia is reliably available without a CDN);
       sans for body. Mono for hex addresses. The serif gives the documents
       a "legal correspondence / banker memo" feel rather than a SaaS feel. */
    --font-serif:  "Georgia", "Times New Roman", "Iowan Old Style", serif;
    --font-body:   "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI",
                   Helvetica, Arial, sans-serif;
    --font-mono:   "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;

    /* Type scale */
    --type-cover:   38pt;
    --type-cover-sub: 13pt;
    --type-h1:      22pt;
    --type-h2:      13pt;
    --type-h3:      11pt;
    --type-body:    10.5pt;
    --type-small:   9pt;
    --type-tiny:    8pt;
    --type-micro:   7.5pt;

    --space-xs:   0.25em;
    --space-sm:   0.5em;
    --space-md:   1em;
    --space-lg:   1.5em;
    --space-xl:   2em;
    --space-xxl:  3em;
    --space-xxxl: 4.5em;

    --doc-max-w: 8in;
  }

  /* ===================================================================
     Reset + page baseline
     =================================================================== */
  @page {
    size: letter;
    margin: 0.6in 0.65in 0.7in 0.65in;
  }
  *, *::before, *::after { box-sizing: border-box; }
  html { -webkit-font-smoothing: antialiased; }
  body {
    font-family: var(--font-body);
    font-size: var(--type-body);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: var(--doc-max-w);
    margin: 0 auto;
    padding: 0.85in 0.75in 0.7in;
    background: var(--paper);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ===================================================================
     Cover — banker / law-firm letterhead aesthetic
     ===================================================================
     Design intent: confidence through restraint. One word of brand at
     the top in serif caps, a thin black rule, the document title set
     huge in Georgia (centered), then a precisely-aligned metadata
     block. No colored chips. No gradient cards. White space is the
     design.
     =================================================================== */
  .cover {
    margin-bottom: var(--space-xxxl);
    padding-bottom: var(--space-xl);
  }
  .cover-letterhead {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 0.6em;
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--space-xxl);
  }
  .cover-wordmark {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 15pt;
    letter-spacing: 0.32em;
    color: var(--ink);
    text-transform: uppercase;
  }
  .cover-wordmark .tagline {
    display: block;
    margin-top: 0.4em;
    font-family: var(--font-body);
    font-size: var(--type-tiny);
    font-weight: 500;
    color: var(--ink-quiet);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .cover-letterhead-right {
    text-align: right;
    font-family: var(--font-body);
    font-size: var(--type-small);
    color: var(--ink-quiet);
    line-height: 1.55;
  }
  .cover-letterhead-right .confidential {
    font-style: italic;
    color: var(--confidential);
    letter-spacing: 0.04em;
  }
  .cover-letterhead-right .date {
    color: var(--ink-soft);
    font-size: var(--type-small);
    margin-top: 0.2em;
  }

  /* Title block — large serif, centered */
  .cover-title-block {
    text-align: center;
    margin: var(--space-xxxl) 0 var(--space-xxl);
  }
  .cover-eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-tiny);
    font-weight: 600;
    color: var(--ink-quiet);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }
  .cover h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: var(--type-cover);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 var(--space-md) 0;
  }
  .cover-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--type-cover-sub);
    line-height: 1.45;
    color: var(--ink-muted);
    max-width: 30em;
    margin: 0 auto;
  }
  .cover-rule {
    display: block;
    width: 56px;
    margin: var(--space-lg) auto 0;
    border-top: 1px solid var(--gold-accent);
    height: 0;
  }

  /* Metadata block — formal "PREPARED FOR / PREPARED BY" layout */
  .cover-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-xl) var(--space-xxl);
    margin: var(--space-xxxl) auto 0;
    max-width: 6.5in;
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
  }
  .cover-meta-item {
    /* tight vertical alignment — labels above values */
  }
  .cover-meta dt {
    font-family: var(--font-body);
    font-size: var(--type-micro);
    font-weight: 600;
    color: var(--ink-quiet);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.5em;
  }
  .cover-meta dd {
    font-family: var(--font-serif);
    font-size: 12pt;
    font-weight: 400;
    color: var(--ink);
    margin: 0;
    line-height: 1.4;
  }
  .cover-meta dd .secondary {
    display: block;
    margin-top: 0.25em;
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--type-small);
    color: var(--ink-muted);
    line-height: 1.45;
  }
  .cover-meta dd.mono {
    font-family: var(--font-mono);
    font-size: 10.5pt;
    font-weight: 500;
    color: var(--ink-soft);
  }

  /* ===================================================================
     Section headings — serif numbered, thin black rule
     =================================================================== */
  h2 {
    font-family: var(--font-serif);
    font-size: var(--type-h2);
    font-weight: 400;
    color: var(--ink);
    margin: var(--space-xxl) 0 var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--rule-soft);
    letter-spacing: 0.005em;
  }
  h2:first-of-type { margin-top: var(--space-xl); }
  h3 {
    font-family: var(--font-body);
    font-size: var(--type-h3);
    font-weight: 600;
    color: var(--ink-soft);
    margin: var(--space-xl) 0 var(--space-sm);
    letter-spacing: 0.005em;
    text-transform: uppercase;
    font-size: var(--type-tiny);
    letter-spacing: 0.16em;
    color: var(--ink-quiet);
  }
  p { margin: 0 0 var(--space-md); }
  ul, ol { margin: var(--space-md) 0; padding-left: 1.5em; }
  ul li, ol li { margin-bottom: var(--space-xs); }

  /* ===================================================================
     Summary / call-out boxes — flatter, less colorful
     =================================================================== */
  .summary-box {
    background: var(--paper-tint);
    border-left: 2px solid var(--rule);
    padding: var(--space-md) var(--space-lg);
    margin: var(--space-lg) 0 var(--space-xl);
  }
  .summary-box.urgent {
    background: var(--urgent-bg);
    border-left-color: var(--urgent-border);
  }
  .summary-box.action {
    background: var(--action-bg);
    border-left-color: var(--action-border);
  }
  .summary-box p:last-child { margin-bottom: 0; }

  /* Attachment-pointer note — used in section 3 of issuer freeze
     letters + LE handoffs to reference the standalone fund-flow SVG
     file. Less visually loud than .summary-box (it's a pointer, not a
     finding) but uses the gold accent rule so it doesn't blend into
     body prose. */
  .attachment-note {
    background: var(--paper-tint);
    border-left: 2px solid var(--gold-accent);
    padding: var(--space-sm) var(--space-md);
    margin: var(--space-md) 0 var(--space-lg);
    font-size: 0.92em;
    color: var(--ink-soft);
  }
  .attachment-note .mono {
    font-weight: 600;
  }

  /* Address hyperlinks — every raw wallet / contract / tx hash in
     the letter is wrapped in <a href="..."> so the rendered PDF
     is fully clickable from a reviewer's desk (WeasyPrint
     converts <a> tags to PDF link annotations).

     Treatment: ethereum-blue text + standard underline. Two
     primitives WeasyPrint has rendered reliably since v40 — no
     CSS variables, no border-bottom (which doesn't survive line
     wrap on long mono content), no modern text-decoration-{color,
     thickness,offset} (which WeasyPrint 60-69 drops). The BLUE
     TEXT alone is the dominant cue; the underline is confirmation.

     Specificity-bumped via !important to override the global `a`
     rule lower in this stylesheet — without this, WeasyPrint
     resolved the global rule's modern text-decoration-color and
     left mono addresses looking like body ink. */
  a.mono,
  .mono a,
  table.evidence a,
  a[href*="etherscan"],
  a[href*="arbiscan"],
  a[href*="basescan"],
  a[href*="polygonscan"],
  a[href*="bscscan"],
  a[href*="solscan"] {
    color: #1D4ED8 !important;
    text-decoration: underline !important;
    /* Allow long hex addresses to wrap at any character — without
       this they overflow the column on narrow body / table cells
       and the PDF gets cut off on the right. */
    word-break: break-all;
    overflow-wrap: anywhere;
  }
  /* Non-mono prose links ("View on Etherscan", "Token transfer
     history") — same color + semibold for visual emphasis since
     they're explicit CTAs in body prose. */
  .summary-box a:not(.mono),
  p a:not(.mono):not([href*="@"]) {
    color: #1D4ED8 !important;
    text-decoration: underline !important;
    font-weight: 600;
  }

  /* Appendix-pointer — narrow inline note replacing the old
     attachment-pointer. Less prominent than .attachment-note because
     the diagram is included in the same document as Appendix A rather
     than referenced as an external file. */
  .appendix-pointer {
    margin: var(--space-md) 0 var(--space-lg);
    padding: var(--space-xs) var(--space-md);
    border-left: 2px solid var(--gold-accent);
    font-size: 0.92em;
    color: var(--ink-soft);
    background: transparent;
  }

  /* ===================================================================
     Appendix — fund flow diagram, etc.
     ===================================================================
     The appendix is intentionally separated from the main body of the
     letter:
       * Page break before — keeps the case narrative whole on the
         preceding pages.
       * Landscape page orientation — the flow diagram is rendered as
         a landscape-shaped SVG (12in × 7.5in target box from
         worker/_flow_diagram.py); printing in landscape lets it
         consume the full page width without scaling artifacts that
         hurt label legibility.
       * Quiet eyebrow + serif title — visually consistent with the
         cover page so the reader knows this is end-matter, not new
         findings.
     =================================================================== */
  @page appendix {
    size: letter landscape;
    margin: 0.45in 0.6in 0.5in 0.6in;
  }
  .appendix {
    page: appendix;
    page-break-before: always;
    break-before: page;
    margin-top: 0;
    padding-top: 0;
  }
  .appendix-eyebrow {
    font-family: var(--font-body);
    font-size: var(--type-tiny);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-accent);
    margin-bottom: 0.3em;
  }
  .appendix-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 22pt;
    color: var(--ink);
    margin: 0 0 0.4em 0;
    padding: 0;
    border: none;
  }
  .appendix-subtitle {
    font-size: var(--type-small);
    color: var(--ink-quiet);
    margin: 0 0 var(--space-md) 0;
    max-width: 9in;
    line-height: 1.55;
  }
  .appendix-flow-frame {
    width: 100%;
    margin: var(--space-sm) 0 var(--space-md);
    padding: var(--space-sm);
    border: 1px solid var(--rule);
    background: var(--paper);
    /* On screen the SVG fits the container width; on print, WeasyPrint
       computes the natural size from the SVG's viewBox and the
       container's available landscape width. */
    overflow: hidden;
    break-inside: avoid;
    page-break-inside: avoid;
  }
  .appendix-flow-frame svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: 7in;
  }
  .appendix-note {
    color: var(--ink-quiet);
    font-size: var(--type-tiny);
    margin-top: var(--space-md);
    line-height: 1.55;
  }

  /* Inline label pills — kept understated. Used for chain-context  */
  /* notes only; not for prominent visual treatment.                */
  .label-pill {
    display: inline-block;
    padding: 0.12em 0.55em;
    border: 1px solid currentColor;
    border-radius: 2px;
    font-size: var(--type-tiny);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: transparent;
  }
  .label-pill.perpetrator { color: #6B0F0F; }
  .label-pill.exchange    { color: #2F6B3E; }
  .label-pill.bridge      { color: #7C2D12; }
  .label-pill.unknown     { color: var(--ink-quiet); }

  /* ===================================================================
     Tables — restrained evidence presentation
     =================================================================== */
  table.evidence {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-md) 0 var(--space-xl);
    font-size: var(--type-small);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  table.evidence th, table.evidence td {
    padding: 0.7em 0.6em;
    text-align: left;
    vertical-align: top;
    border-top: 1px solid var(--rule-soft);
  }
  table.evidence thead th {
    font-weight: 600;
    color: var(--ink-quiet);
    border-top: none;
    border-bottom: 1px solid var(--rule);
    font-size: var(--type-micro);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding-bottom: 0.55em;
  }
  table.evidence tbody tr:first-child td { border-top: none; }
  table.evidence td.mono, table.evidence td.amount {
    font-family: var(--font-mono);
    font-weight: 500;
    word-break: break-all;
    color: var(--ink);
  }
  table.evidence td.amount {
    text-align: right;
    white-space: nowrap;
    font-feature-settings: "tnum" 1;
  }
  /* Two-column "th in left col" layout used in metadata tables */
  table.evidence tr > th:first-child:not(:only-child) {
    width: 12em;
    font-weight: 500;
    color: var(--ink-quiet);
    border-bottom: 1px solid var(--rule-soft);
    background: transparent;
    text-transform: none;
    letter-spacing: 0;
    font-size: var(--type-small);
  }
  .perp-row    { background: var(--color-perp-tint)   !important; }
  .victim-row  { background: var(--color-victim-tint) !important; }

  /* ===================================================================
     Mono utility + links + inline annotations
     =================================================================== */
  .mono {
    font-family: var(--font-mono);
    font-weight: 500;
    word-break: break-all;
    overflow-wrap: anywhere;
    font-feature-settings: "tnum" 1;
  }
  .small { font-size: var(--type-small); color: var(--ink-quiet); }
  /* Default `a` styling — falls back to the address-link rule
     above for anything matching the explorer-href patterns. Plain
     prose links (non-clickable internal anchors, mailto, etc.)
     get a quiet inherit-color + no underline so we don't end up
     with a wall of blue text. Using literal values only —
     WeasyPrint 60-69 drops the modern text-decoration-{color,
     thickness,offset} CSS3 properties. */
  a {
    color: inherit;
    text-decoration: none;
  }

  /* Flow-diagram inline card removed in commit aa7dce7. The fund-flow
     SVG is now a separate file referenced via .attachment-note in the
     letter; the inline embed produced unusable 21:1 aspect ratios. */

  /* ===================================================================
     Timeline — quiet, monochrome
     =================================================================== */
  .timeline {
    border-left: 1px solid var(--rule-soft);
    padding-left: var(--space-lg);
    margin: var(--space-md) 0;
  }
  .timeline-event {
    margin-bottom: var(--space-md);
    position: relative;
  }
  .timeline-event::before {
    content: "";
    position: absolute;
    left: -1.55em;
    top: 0.5em;
    width: 0.55em; height: 0.55em;
    border-radius: 50%;
    background: var(--paper);
    border: 1.5px solid var(--ink);
  }
  .timeline-event.theft::before    { background: #6B0F0F; border-color: #6B0F0F; }
  .timeline-event.transfer::before { background: var(--gold-accent); border-color: var(--gold-accent); }
  .timeline-event.current::before  { background: #2F6B3E; border-color: #2F6B3E; }
  .timeline-event time {
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: var(--type-small);
    color: var(--ink);
  }

  /* ===================================================================
     Signature block + footer — letterhead-style closing
     =================================================================== */
  .signature-block {
    margin-top: var(--space-xxl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--rule-soft);
  }
  .signature-line {
    margin-top: var(--space-xxl);
    border-bottom: 1px solid var(--ink);
    width: 18em;
    height: 1.5em;
  }
  .signature-fields {
    margin-top: var(--space-sm);
    font-size: var(--type-small);
    color: var(--ink-muted);
    line-height: 1.6;
  }
  .signature-fields strong {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 11pt;
    color: var(--ink);
    display: block;
    margin-bottom: 0.15em;
  }

  footer.brief-footer {
    margin-top: var(--space-xxxl);
    padding: var(--space-md) 0 var(--space-sm);
    border-top: 1px solid var(--rule);
    font-family: var(--font-body);
    font-size: var(--type-micro);
    color: var(--ink-quiet);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    letter-spacing: 0.04em;
  }
  footer.brief-footer .footer-brand {
    font-family: var(--font-serif);
    font-size: 10pt;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }
  footer.brief-footer .footer-meta {
    text-align: right;
    line-height: 1.8;
  }
  footer.brief-footer .footer-meta .confidential {
    font-style: italic;
    color: var(--confidential);
  }
  footer.brief-footer code {
    font-family: var(--font-mono);
    font-size: var(--type-micro);
    color: var(--ink-soft);
    letter-spacing: 0;
  }

  /* ===================================================================
     Print / PDF rules
     =================================================================== */
  @media print {
    body {
      max-width: none;
      margin: 0; padding: 0;
      font-size: 10pt;
      line-height: 1.45;
    }
    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    h1, h2, h3, h4 {
      page-break-after: avoid;
      break-after: avoid;
    }
    .summary-box, .meta-grid, .signature-block, .timeline-event,
    .cover, .attachment-note {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    table.evidence { page-break-inside: auto; }
    table.evidence thead { display: table-header-group; }
    table.evidence tfoot { display: table-footer-group; }
    table.evidence tr {
      page-break-inside: avoid;
      break-inside: avoid;
    }
    td.mono, .mono {
      word-break: normal;
      overflow-wrap: anywhere;
    }
    a {
      color: inherit;
      text-decoration: underline;
    }
    .no-print, nav, button { display: none !important; }
    section { page-break-inside: auto; }
    .cover { page-break-after: avoid; break-after: avoid; }
    table.evidence th, table.evidence td {
      padding: 0.4em 0.6em;
      font-size: 8.5pt;
    }
    /* New page after the cover so the first body section starts clean */
    .cover + h2 { page-break-before: always; }
  }
</style>
