</p>

{# Aggregate roll-up panel #}
<div class="summary-box">
  <p style="margin:0">
    <strong>Aggregate.</strong>
    {{ live_status.aggregate.letters_with_response }} of
    {{ live_status.aggregate.total_letters }} issuer{{ "s" if live_status.aggregate.total_letters != 1 else "" }}
    {{ "have" if live_status.aggregate.letters_with_response != 1 else "has" }} responded.
    <strong>{{ live_status.aggregate.total_confirmed_frozen_usd_human }}</strong>
    confirmed frozen of
    <strong>{{ live_status.aggregate.total_requested_usd_human }}</strong>
