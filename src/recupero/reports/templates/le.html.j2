        {% else %}
        <span class="small secondary">insufficient sample</span>
        {% endif %}
      </td>
      <td>
        {% if prof.get('median_response_hours') is not none %}
        {{ "%.0f"|format(prof.get('median_response_hours')) }}h
        {% else %}—{% endif %}
      </td>
      <td>
        {% if prof.get('has_confident_profile') %}
        {{ "%.0f%%"|format((prof.get('full_freeze_rate') or 0) * 100) }}
        {% else %}—{% endif %}
      </td>
      <td><strong>{{ prof.get('recommended_instrument') or 'standard' }}</strong>
