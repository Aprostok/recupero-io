</table>

{# Monitoring snapshot #}
<h3>Active monitoring</h3>
<p class="small">
  {% if live_status.monitoring.active_subscriptions > 0 %}
  This case has <strong>{{ live_status.monitoring.active_subscriptions }}</strong>
  active wallet-monitoring subscription{{ "s" if live_status.monitoring.active_subscriptions != 1 else "" }}
  registered with Recupero. Since the brief was generated,
  <strong>{{ live_status.monitoring.alerts_fired_since_brief }}</strong>
  alert{{ "s" if live_status.monitoring.alerts_fired_since_brief != 1 else "" }}
  {{ "have" if live_status.monitoring.alerts_fired_since_brief != 1 else "has" }}
  fired{% if live_status.monitoring.last_alert_at %}
  (most recent: {{ live_status.monitoring.last_alert_at.strftime("%Y-%m-%d %H:%M") }} UTC){% endif %}.
  Any movement on a monitored wallet is captured in real time and
