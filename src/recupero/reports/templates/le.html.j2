  {% endif %}
</ol>

{% if le_routing and le_routing.has_routes %}
<h2>6.1 Suggested Filing Routes</h2>
<p>
  The following channels are the recommended filing destinations for
  this case, based on the victim's location and the scale of loss.
  Filing in parallel across multiple channels is the norm —
  IC3 establishes the federal record; state-level filings engage
  state-prosecutorial resources the FBI doesn't have; loss-tier
  escalations engage specialized federal units.
</p>

{% if le_routing.primary_routes %}
<h3>Primary (federal / always-applicable)</h3>
<table class="evidence">
  <thead>
    <tr><th>Channel</th><th>Jurisdiction</th><th>Contact</th><th>Why</th></tr>
  </thead>
  <tbody>
    {% for route in le_routing.primary_routes %}
    <tr>
      <td><strong>{{ route.name }}</strong></td>
      <td>{{ route.jurisdiction }}</td>
      <td class="small">
        {% if route.url %}<a href="{{ route.url|safe_url }}">{{ route.url }}</a><br/>{% endif %}
        {% if route.email %}<a href="{{ ('mailto:' ~ route.email)|safe_url }}">{{ route.email }}</a><br/>{% endif %}
        {% if route.phone %}{{ route.phone }}<br/>{% endif %}
        {% if route.expected_response %}<span class="small">Response: {{ route.expected_response }}</span>{% endif %}
      </td>
      <td class="small">{{ route.description }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% if le_routing.state_routes %}
<h3>State-level (US)</h3>
<table class="evidence">
  <thead>
    <tr><th>Channel</th><th>Jurisdiction</th><th>Contact</th><th>Why</th></tr>
  </thead>
  <tbody>
    {% for route in le_routing.state_routes %}
    <tr>
      <td><strong>{{ route.name }}</strong></td>
      <td>{{ route.jurisdiction }}</td>
      <td class="small">
        {% if route.url %}<a href="{{ route.url|safe_url }}">{{ route.url }}</a><br/>{% endif %}
        {% if route.email %}<a href="{{ ('mailto:' ~ route.email)|safe_url }}">{{ route.email }}</a><br/>{% endif %}
        {% if route.phone %}{{ route.phone }}<br/>{% endif %}
      </td>
      <td class="small">{{ route.description }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% if le_routing.escalation_routes %}
<h3>Loss-tier escalations</h3>
<table class="evidence">
  <thead>
    <tr><th>Channel</th><th>Jurisdiction</th><th>Contact</th><th>Why</th></tr>
  </thead>
  <tbody>
    {% for route in le_routing.escalation_routes %}
    <tr>
      <td><strong>{{ route.name }}</strong></td>
      <td>{{ route.jurisdiction }}</td>
      <td class="small">
        {% if route.url %}<a href="{{ route.url|safe_url }}">{{ route.url }}</a><br/>{% endif %}
        {% if route.email %}<a href="{{ ('mailto:' ~ route.email)|safe_url }}">{{ route.email }}</a><br/>{% endif %}
        {% if route.phone %}{{ route.phone }}<br/>{% endif %}
        {% if route.expected_response %}<span class="small">Response: {{ route.expected_response }}</span>{% endif %}
      </td>
      <td class="small">{{ route.description }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% if le_routing.notes %}
<div class="summary-box">
  <p style="margin:0 0 0.5em 0;"><strong>Filing notes:</strong></p>
  <ul style="margin:0;">
    {% for note in le_routing.notes %}
    <li class="small">{{ note }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}
{% endif %}

<h2>7. Service Providers Involved</h2>
<table class="evidence">
  <tr>
    <th>Service</th><th>Role</th><th>Why relevant</th><th>Suggested contact</th>
  </tr>
  <tr>
    <td>{{ issuer.name }}</td>
    {% if issuer_freezable %}
    <td>Issuer of {{ issuer_freezable.token }} (recoverable positions held under their authority)</td>
    <td>Protocol-level control over {{ issuer_freezable.token }} redemption at the addresses in section 4.1; primary freeze target</td>
    {% else %}
    <td>Issuer of stolen {{ asset.symbol }} wrapper token</td>
    <td>Has protocol-level control over redemption; primary freeze target</td>
    {% endif %}
    <td>{{ issuer.contact_email }} (request escalation to compliance)</td>
  </tr>
  {% if issuer.secondary_party and issuer.secondary_role %}
  <tr>
    <td>{{ issuer.secondary_party }}</td>
    <td>{{ issuer.secondary_role|capitalize }}</td>
    <td>Controls underlying strategy; secondary freeze route</td>
    <td>(public compliance channel)</td>
  </tr>
  {% endif %}
</table>

{# v0.19.1 (round-12 PDF-HIGH-7): chain-parameterized attestation prose.
   Pre-v0.19.1 the verification + attestation sections hardcoded
   "Ethereum mainnet" and "Etherscan" — every Solana/Tron/BSC/BTC LE
   handoff therefore signed an attestation contradicting the actual
   chain shown on the cover. Compliance reviewers reject the package
   on the attestation alone. Now: `primary_chain` populates the
   chain-name banner and the explorer name follows. #}
<h2>8. Verification</h2>
<p>
  Every fact in this package is drawn from public {{ primary_chain | default("Ethereum") }}
  on-chain state and is independently verifiable. Each transaction listed
  in the timeline links to its block-explorer record. For each transaction
  we retain, on file: the raw transaction object, receipt, block header,
  fetch timestamp, and direct verification link.
</p>
<p class="small">
  Sources: on-chain RPC + chain-explorer API (transaction history);
  CoinGecko (historical pricing); our internal label database for entity
  attribution.
</p>

<h2>9. Investigator Attestation</h2>
<div class="signature-block">
  <p>
    I prepared this package on behalf of {{ victim.name }} from public
    {{ primary_chain | default("Ethereum") }} on-chain data fetched between
    {{ trace_started_at or generated_at }} and {{ generated_at }} UTC. The transaction
    hashes, addresses, timestamps, and amounts set out in this brief are
    accurate to the best of my knowledge and were independently verified
    at the time of fetch.
  </p>
  <div class="signature-line"></div>
  <div class="signature-fields">
    <strong>{{ investigator.name }}</strong> · {{ investigator.organization }}<br/>
    Date: __________________________
  </div>
</div>


<footer class="brief-footer">
  <div class="footer-brand">Recupero · Investigation Services</div>
  <div class="footer-meta">
    <code>{{ brief_id }}</code><br/>
    Generated {{ generated_at }} UTC · v{{ software_version }}<br/>
    <span class="confidential">Strictly Confidential.</span> Intended only for the receiving agency.
  </div>
</footer>

</body>
</html>
