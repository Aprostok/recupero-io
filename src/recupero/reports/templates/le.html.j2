    {{ issuer_freezable.freezable_count }}
    <strong>FREEZABLE</strong>
    {{ "address" if issuer_freezable.freezable_count == 1 else "addresses" }}
    ({{ issuer_freezable.total_usd_freezable }} total) are the
    primary targets;
    {% if issuer_freezable.has_investigate %}
    the {{ issuer_freezable.investigate_count }}
    <strong>INVESTIGATE</strong> addresses additionally warrant a
