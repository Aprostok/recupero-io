<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>LE Handoff Package — Case {{ case_id }}</title>
{% include "_styles.html.j2" %}
</head>
<body{% if draft %} class="draft" data-draft-label="{{ draft_label | default('DRAFT') }}"{% endif %}>

<section class="cover">
  <div class="cover-letterhead">
    <div class="cover-wordmark">
      Recupero
      <span class="tagline">Investigation Services</span>
    </div>
    <div class="cover-letterhead-right">
      <div class="confidential">Strictly Private &amp; Confidential</div>
      <div class="date">{{ generated_at }} UTC</div>
    </div>
  </div>

  <div class="cover-title-block">
    <div class="cover-eyebrow">Investigative Findings &amp; Recommended Actions</div>
    <h1>Law Enforcement<br/>Handoff Package</h1>
    <p class="cover-subtitle">
      Independent on-chain trace and identified-wallet record prepared for
      handoff to the assigned investigator or supervising agency.
    </p>
    <div class="cover-rule"></div>
  </div>

  <dl class="cover-meta">
    <div class="cover-meta-item">
      <dt>Prepared On Behalf Of</dt>
      <dd>{{ victim.name }}<span class="secondary">{{ victim.citizenship or "Citizenship not on record" }}</span></dd>
    </div>
    <div class="cover-meta-item">
      <dt>Prepared By</dt>
      <dd>{{ investigator.name }}<span class="secondary">{{ investigator.organization }}<br/>{{ investigator.email }}</span></dd>
    </div>
    <div class="cover-meta-item">
      <dt>Case Number</dt>
      <dd>{{ case_id }}</dd>
    </div>
    <div class="cover-meta-item">
      <dt>Brief Identifier</dt>
      <dd class="mono">{{ brief_id }}</dd>
    </div>
    {% if ic3_case_id %}
    {# v0.18.6 (round-11 PDF-CRIT-006): IC3 reference rendered when
       operator captured it at intake. FBI uses this to cross-reference
       the IC3 complaint record; pre-v0.18.6 the LE handoff dropped
       it entirely. #}
    <div class="cover-meta-item">
      <dt>IC3 Reference</dt>
      <dd class="mono">{{ ic3_case_id }}</dd>
    </div>
    {% endif %}
    <div class="cover-meta-item">
      <dt>Stolen Value (Initial)</dt>
      {# v0.20.2 (audit-round-3 R3-3): headline USD reflects the
         TOTAL across all theft_events on a multi-event drain
         (V-CFI01 shape: 6 × $600K = $3.6M total). The narrative
         paragraphs below still show the primary event's USD,
         which is correct (each narrative paragraph describes one
         specific tx). #}
      <dd>USD {{ asset.total_usd_value_at_theft if asset.is_multi_event else asset.usd_value_at_theft }}<span class="secondary">{{ asset.symbol }} on {{ primary_chain | default("Ethereum") }}</span></dd>
    </div>
    {# v0.21.0: recovery probability surfaced on the cover. AUSAs /
       FBI agents weigh case priority on this number before reading
       any per-issuer detail. Hidden when the scorer wasn't run
       (older briefs) or returned no estimate. Field names match
       RecoveryEstimate.to_json_safe(). Uses .get() so missing keys
       under StrictUndefined degrade gracefully rather than raising. #}
    {% if recovery_estimate and recovery_estimate.get('expected_recovered_usd') %}
    <div class="cover-meta-item">
      <dt>Estimated Recoverable</dt>
      <dd>{{ recovery_estimate.get('expected_recovered_usd') }}<span class="secondary">range {{ recovery_estimate.get('expected_recovered_low_usd') or '—' }} – {{ recovery_estimate.get('expected_recovered_high_usd') or '—' }} (90% CI){% if recovery_estimate.get('probability_any_recovery_90d') is not none %} · {{ "%.0f%%"|format(recovery_estimate.get('probability_any_recovery_90d') * 100) }} probability of any recovery within 90d{% endif %}</span></dd>
    </div>
    {% endif %}
    <div class="cover-meta-item">
      <dt>Asset Issuer</dt>
      <dd>{{ issuer.name }}{% if issuer.jurisdiction %}<span class="secondary">{{ issuer.jurisdiction }}</span>{% endif %}</dd>
    </div>
    {% if issuer_freezable %}
    {# Cover-meta label is evidence-mode aware. #}
    <div class="cover-meta-item">
      {% if issuer_freezable.evidence_mode == "historical_only" %}
      <dt>Documented Position</dt>
      <dd>{{ issuer_freezable.total_usd_freezable }}<span class="secondary">{{ issuer_freezable.token }} received at {{ issuer_freezable.historical_count }} {{ "wallet" if issuer_freezable.historical_count == 1 else "wallets" }} ({{ issuer_freezable.freeze_capability }} freeze capability, historical receipt)</span></dd>
      {% else %}
      <dt>Recoverable Position</dt>
      <dd>{{ issuer_freezable.total_usd_freezable }}<span class="secondary">{{ issuer_freezable.token }} at {{ issuer_freezable.freezable_count }} {{ "wallet" if issuer_freezable.freezable_count == 1 else "wallets" }} ({{ issuer_freezable.freeze_capability }} freeze capability{% if issuer_freezable.evidence_mode == "mixed" %}, mixed evidence{% endif %})</span></dd>
      {% endif %}
    </div>
    {% if issuer_freezable.has_investigate %}
    <div class="cover-meta-item">
      <dt>Additional Under Review</dt>
      <dd>{{ issuer_freezable.total_usd_suspected }}<span class="secondary">incl. {{ issuer_freezable.investigate_count }} wallets pending KYC verification</span></dd>
    </div>
    {% endif %}
    {% endif %}
  </dl>
</section>

<h2>1. Executive Summary</h2>
<div class="summary-box">
  <p style="margin:0 0 0.7em 0;">
    On {{ theft_event.timestamp_human }} UTC, {{ asset.amount_human }}
    {{ asset.symbol }} (USD {{ asset.usd_value_at_theft }} at the time of
    transaction) was removed without authorization from
    {{ victim.name }}'s wallet
    {% if victim.citizenship %}(citizen of {{ victim.citizenship }}){% endif %}.
    {# JACOB-2 fix: this sentence narrates the ORIGINAL stolen asset's
       issuer (Tether for USDT, Midas for mSyrupUSDp). Pre-fix it
       echoed `issuer.name` — the FREEZE-TARGET issuer — so a Circle
       freeze letter for a USDT theft read "USDT was removed... The
       token is issued by Circle." Now uses `asset.issuer`, which is
       resolved via `_resolve_theft_asset_issuer_name()` from the
       theft transfer's contract address. The freeze-target issuer
       still appears throughout the rest of the letter (the
       `issuer_freezable` paragraphs below, Section 3, etc.) where
       they correctly describe whom we're asking to act.
       The jurisdiction + secondary-party clauses were ALSO keyed on
       `issuer` (the freeze-target). They've been removed from this
       sentence — they were always wrong for cross-issuer letters
       (e.g., Coinbase letter saying USDT is "a Coinbase entity" was
       nonsense) and right only for the rare self-issuer case (Midas
       letter about mSyrupUSDp). Section 2 of this same LE handoff
       still surfaces the freeze-target's jurisdiction in the
       "Issuer (legal entity)" row, so no fact is lost. #}
    The token is issued by {{ asset.issuer }}.
  </p>
  {% if issuer_freezable %}
  {# Executive summary branches on evidence_mode — historical_only
     must NOT assert current custody (this letter goes to LE). #}
  {% if issuer_freezable.evidence_mode == "historical_only" %}
  <p style="margin:0 0 0.7em 0;">
    The position was forwarded by the perpetrator through a chain of
    intermediate wallets and converted into
    <strong>{{ issuer_freezable.token }}</strong>, the stablecoin
    issued by {{ issuer.name }}. On-chain tracing documents that
    <strong>{{ issuer_freezable.total_usd_freezable }}</strong> in
    {{ issuer_freezable.token }} was received at
    {{ issuer_freezable.historical_count }}
    {{ "wallet" if issuer_freezable.historical_count == 1 else "wallets" }}
    under {{ issuer.short_name }}'s issuance authority during the
    documented theft trail{% if issuer_freezable.earliest_observed %} (earliest observation {{ issuer_freezable.earliest_observed[:10] }}){% endif %}.
    Current balances at those addresses are pending issuer
    verification — these positions are flagged in section 4.1 with
    per-address evidence-type provenance.
    {% if issuer_freezable.has_investigate %}
    An additional
    {{ issuer_freezable.investigate_count }}
    {{ "wallet" if issuer_freezable.investigate_count == 1 else "wallets" }}
    are flagged INVESTIGATE, representing
    {{ issuer_freezable.total_usd_suspected }} in further funds
    pending verification.
    {% endif %}
  </p>
  <p style="margin:0;">
    {{ issuer.short_name }}'s protocol-level controls over
    {{ issuer_freezable.token }} provide the mechanism for
    investigating current disposition of the documented receipts
    and pausing redemption of any balances that remain. We recommend
    that a preservation request be issued to {{ issuer.short_name }}
    as a matter of priority, citing the addresses listed in section 5.
  </p>
  {% elif issuer_freezable.evidence_mode == "mixed" %}
  <p style="margin:0 0 0.7em 0;">
    The position was forwarded by the perpetrator through a chain of
    intermediate wallets and converted into
    <strong>{{ issuer_freezable.token }}</strong>, the stablecoin
    issued by {{ issuer.name }}. As of {{ verified_at }} UTC,
    <strong>{{ issuer_freezable.total_usd_freezable }}</strong>
    of stolen funds is associated with
    {{ issuer_freezable.freezable_count }}
    {{ "wallet" if issuer_freezable.freezable_count == 1 else "wallets" }}
    under {{ issuer.short_name }}'s issuance authority — a mix of
    {{ issuer_freezable.current_balance_count }} confirmed current-
    balance positions and {{ issuer_freezable.historical_count }}
    documented historical receipts (section 4.1 details per-address
    evidence type).
    {% if issuer_freezable.has_investigate %}
    An additional
    {{ issuer_freezable.investigate_count }}
    {{ "wallet" if issuer_freezable.investigate_count == 1 else "wallets" }}
    are flagged INVESTIGATE, representing
    {{ issuer_freezable.total_usd_suspected }} pending verification.
    {% endif %}
  </p>
  <p style="margin:0;">
    {{ issuer.short_name }}'s protocol-level controls over
    {{ issuer_freezable.token }} are the available mechanism for
    pausing redemption of the confirmed positions and investigating
    the historical-receipt addresses. We recommend that a preservation
    request be issued to {{ issuer.short_name }} as a matter of
    priority, citing the addresses listed in section 5.
  </p>
  {% else %}
  <p style="margin:0 0 0.7em 0;">
    The position was forwarded by the perpetrator through a chain of
    intermediate wallets and converted into
    <strong>{{ issuer_freezable.token }}</strong>, the stablecoin
    issued by {{ issuer.name }}. As of {{ verified_at }} UTC,
    <strong>{{ issuer_freezable.total_usd_freezable }}</strong>
    of stolen funds is held in {{ issuer_freezable.token }} at
    {{ issuer_freezable.freezable_count }}
    {{ "wallet" if issuer_freezable.freezable_count == 1 else "wallets" }}
    under {{ issuer.short_name }}'s issuance authority — these
    positions are flagged FREEZABLE in section 4.1.
    {% if issuer_freezable.has_investigate %}
    An additional
    {{ issuer_freezable.investigate_count }}
    {{ "wallet" if issuer_freezable.investigate_count == 1 else "wallets" }}
    holding {{ issuer_freezable.token }} are flagged INVESTIGATE,
    representing
    {{ issuer_freezable.total_usd_suspected }}
    in further funds pending KYC verification at {{ issuer.short_name }}.
    {% endif %}
  </p>
  <p style="margin:0;">
    {{ issuer.short_name }}'s protocol-level controls over
    {{ issuer_freezable.token }} are the available mechanism for
    pausing redemption of the recoverable positions. We recommend
    that a preservation request be issued to {{ issuer.short_name }}
    as a matter of priority, citing the addresses listed in
    section 5 of this package.
  </p>
  {% endif %}
  {% else %}
  <p style="margin:0 0 0.7em 0;">
    The position was promptly forwarded by the perpetrator to a secondary
    wallet at {% if current_holder.explorer_url %}<a class="mono" href="{{ current_holder.explorer_url|safe_url }}">{{ current_holder.address }}</a>{% else %}<span class="mono">{{ current_holder.address }}</span>{% endif %}, where
    {{ outbound_count_of_stolen_asset }} outbound transfers have been
    observed as of {{ verified_at }} UTC.
  </p>
  <p style="margin:0;">
    The asset's issuer-level controls remain the only available
    mechanism by which redemption can be paused. We recommend that
    a preservation request be issued to {{ issuer.short_name }} as a
    matter of priority.
  </p>
  {% endif %}
</div>

<h2>2. Victim Information</h2>
<dl class="meta-grid">
  <dt>Full name:</dt>           <dd>{{ victim.name }}</dd>
  {% if victim.citizenship %}<dt>Citizenship:</dt><dd>{{ victim.citizenship }}</dd>{% endif %}
  {% if victim.address %}<dt>Residential address:</dt><dd>{{ victim.address }}</dd>{% endif %}
  {% if victim.email %}<dt>Email:</dt>      <dd>{{ victim.email }}</dd>{% endif %}
  {% if victim.phone %}<dt>Phone:</dt>      <dd>{{ victim.phone }}</dd>{% endif %}
  <dt>Affected wallet:</dt>     <dd>{% if victim_wallet_explorer_url %}<a class="mono" href="{{ victim_wallet_explorer_url|safe_url }}">{{ victim.wallet_address }}</a>{% else %}<span class="mono">{{ victim.wallet_address }}</span>{% endif %}</dd>
  {% if victim.legal_counsel %}
  <dt>Legal counsel:</dt><dd>{{ victim.legal_counsel }}{% if victim.legal_counsel_email %} &lt;{{ victim.legal_counsel_email }}&gt;{% endif %}</dd>
  {% endif %}
</dl>

{% if victim.incident_summary %}
<h3>Victim's account of the incident</h3>
<p>{{ victim.incident_summary }}</p>
{% endif %}

<h2>3. Timeline of Events (UTC)</h2>
{% if theft_event_count and theft_event_count > 1 %}
<p class="small">
  This drain involved <strong>{{ theft_event_count }} unauthorized
  outbound transfers</strong> from the victim wallet within a 7-day
  window, totaling <strong>USD {{ theft_event_total_usd }}</strong>.
  Each is listed below in chronological order. The "primary" event is
  the highest-USD transfer and is the headline transaction described
  in section 2.
</p>
{% endif %}
<div class="timeline">
  {% if theft_events and theft_event_count > 1 %}
    {% for ev in theft_events %}
    <div class="timeline-event theft">
      <time>{{ ev.timestamp_human }}</time> &nbsp;—&nbsp;
      <strong>{% if ev.is_primary %}Primary theft event.{% else %}Drain event.{% endif %}</strong>
      {{ ev.amount_human }} {{ ev.symbol }}
      {% if ev.usd_value and ev.usd_value != '(unknown)' %}(USD {{ ev.usd_value }}){% endif %}
      transferred from
      {% if ev.from_explorer_url %}<a class="mono" href="{{ ev.from_explorer_url|safe_url }}">{{ ev.from_address }}</a>{% else %}<span class="mono">{{ ev.from_address }}</span>{% endif %}
      to {% if ev.to_explorer_url %}<a class="mono" href="{{ ev.to_explorer_url|safe_url }}">{{ ev.to_address }}</a>{% else %}<span class="mono">{{ ev.to_address }}</span>{% endif %}.
      Tx: <span class="mono">{% if ev.explorer_url %}<a href="{{ ev.explorer_url|safe_url }}">{{ ev.tx_hash }}</a>{% else %}{{ ev.tx_hash }}{% endif %}</span>
    </div>
    {% endfor %}
  {% else %}
  <div class="timeline-event theft">
    <time>{{ theft_event.timestamp_human }}</time> &nbsp;—&nbsp;
    <strong>Initial theft.</strong> {{ asset.amount_human }} {{ asset.symbol }} transferred
    from victim wallet {% if theft_event.from_explorer_url %}<a class="mono" href="{{ theft_event.from_explorer_url|safe_url }}">{{ theft_event.from_address }}</a>{% else %}<span class="mono">{{ theft_event.from_address }}</span>{% endif %}
    to perpetrator wallet {% if theft_event.to_explorer_url %}<a class="mono" href="{{ theft_event.to_explorer_url|safe_url }}">{{ theft_event.to_address }}</a>{% else %}<span class="mono">{{ theft_event.to_address }}</span>{% endif %}.
    Tx: <span class="mono">{% if theft_event.explorer_url %}<a href="{{ theft_event.explorer_url|safe_url }}">{{ theft_event.tx_hash }}</a>{% else %}{{ theft_event.tx_hash }}{% endif %}</span>
  </div>
  {% endif %}
  {% for hop in hops %}
  <div class="timeline-event transfer">
    <time>{{ hop.timestamp_human }}</time> &nbsp;—&nbsp;
    <strong>Hop {{ loop.index }}.</strong>
    {{ hop.amount_human }} {{ hop.symbol }} transferred from
    {% if hop.from_explorer_url %}<a class="mono" href="{{ hop.from_explorer_url|safe_url }}">{{ hop.from_address }}</a>{% else %}<span class="mono">{{ hop.from_address }}</span>{% endif %}
    to {% if hop.to_explorer_url %}<a class="mono" href="{{ hop.to_explorer_url|safe_url }}">{{ hop.to_address }}</a>{% else %}<span class="mono">{{ hop.to_address }}</span>{% endif %}.
    Tx: <span class="mono">{% if hop.explorer_url %}<a href="{{ hop.explorer_url|safe_url }}">{{ hop.tx_hash }}</a>{% else %}{{ hop.tx_hash }}{% endif %}</span>
  </div>
  {% endfor %}
  <div class="timeline-event current">
    <time>{{ verified_at }}</time> &nbsp;—&nbsp;
    {% if issuer_freezable %}
    {# Timeline "Current state" branches on evidence_mode. #}
    {% if issuer_freezable.evidence_mode == "historical_only" %}
    <strong>Documented receipts.</strong>
    {{ issuer_freezable.total_usd_freezable }} in
    {{ issuer_freezable.token }} received at
    {{ issuer_freezable.historical_count }}
    {{ "wallet" if issuer_freezable.historical_count == 1 else "wallets" }}
    under {{ issuer.short_name }}'s issuance authority during the
    documented theft trail; current balances pending issuer
    verification. Specific addresses enumerated in section 5.
    {% elif issuer_freezable.evidence_mode == "mixed" %}
    <strong>Current state.</strong>
    {{ issuer_freezable.total_usd_freezable }} in
    {{ issuer_freezable.token }} associated with
    {{ issuer_freezable.freezable_count }} addresses
    ({{ issuer_freezable.current_balance_count }} confirmed current
    balances + {{ issuer_freezable.historical_count }} historical
    receipts) under {{ issuer.short_name }}'s issuance authority.
    Specific addresses + per-address evidence type enumerated in
    section 5.
    {% else %}
    <strong>Current state.</strong> Recoverable funds totaling
    {{ issuer_freezable.total_usd_freezable }} held as
    {{ issuer_freezable.token }} across
    {{ issuer_freezable.freezable_count }}
    {{ "wallet" if issuer_freezable.freezable_count == 1 else "wallets" }}
    under {{ issuer.short_name }}'s issuance authority
    {% if issuer_freezable.has_investigate %}
    (plus {{ issuer_freezable.investigate_count }} additional
    {{ issuer_freezable.token }} positions under KYC verification).
    {% else %}.{% endif %}
    Specific addresses enumerated in section 5.
    {% endif %}
    {% else %}
    <strong>Current state.</strong> Position remains in
    {% if current_holder.explorer_url %}<a class="mono" href="{{ current_holder.explorer_url|safe_url }}">{{ current_holder.address }}</a>{% else %}<span class="mono">{{ current_holder.address }}</span>{% endif %}.
    {{ outbound_count_of_stolen_asset }} outbound transfers of the stolen asset observed
    since receipt.
    {% endif %}
  </div>
</div>

{% if flow_filename %}
<h2>3.1 Fund Flow Diagram</h2>
<p class="attachment-note">
  The fund-flow diagram is provided as a separate SVG attachment
  (<span class="mono">{{ flow_filename }}</span>) accompanying this
  package. Open in any modern browser for full-resolution inspection;
  each wallet node links to its {{ primary_chain_explorer_name }} record. Solid arrows
  represent observed on-chain transfers, with edge labels showing
  USD-denominated value at the time of transfer and line thickness
  scaled logarithmically to value.
</p>
{% endif %}

<h2>4. Stolen Asset Details</h2>
<table class="evidence">
  <tr><th>Asset symbol</th>           <td>{{ asset.symbol }}</td></tr>
  <tr><th>Token contract address</th> <td>{% if asset_contract_explorer_url %}<a class="mono" href="{{ asset_contract_explorer_url|safe_url }}">{{ asset.contract }}</a>{% else %}<span class="mono">{{ asset.contract }}</span>{% endif %}</td></tr>
  <tr><th>Issuer (legal entity)</th>  <td>{{ asset.issuer }}</td></tr>
  {% if issuer.jurisdiction %}<tr><th>Issuer jurisdiction</th><td>{{ issuer.jurisdiction }}</td></tr>{% endif %}
  {% if issuer.secondary_party and issuer.secondary_role %}<tr><th>Underlying strategy operator</th><td>{{ issuer.secondary_party }} ({{ issuer.secondary_role }})</td></tr>{% endif %}
  <tr><th>Asset description</th>      <td>{{ asset.description }}</td></tr>
  {# v0.20.2 (audit-round-3 R3-3): evidence table rolls up to the
     full multi-event total when applicable; the narrative above
     enumerates each event. #}
  <tr><th>Amount{% if asset.is_multi_event %} (total across {{ asset.theft_event_count }} events){% endif %}</th>                 <td class="amount">{{ asset.total_amount_human if asset.is_multi_event else asset.amount_human }}</td></tr>
  <tr><th>USD value at time of theft</th><td class="amount">USD {{ asset.total_usd_value_at_theft if asset.is_multi_event else asset.usd_value_at_theft }}</td></tr>
  {% if asset.usd_value_current %}
  <tr><th>USD value (current estimate)</th><td class="amount">USD {{ asset.usd_value_current }}</td></tr>
  {% endif %}
  {% if issuer.kyc_required %}
  <tr><th>KYC requirement at acquisition</th><td>Yes — {{ issuer.short_name }} required full identity verification{% if issuer.kyc_minimum %} with minimum subscription of {{ issuer.kyc_minimum }}{% endif %}</td></tr>
  {% endif %}
</table>

{% if issuer_freezable %}
<h2>4.1 Recoverable Positions under {{ issuer.short_name }}'s Authority</h2>
<p>
  After tracing through the perpetrator's on-chain forwarding,
  the following {{ issuer_freezable.total_count }}
  {{ "wallet holds" if issuer_freezable.total_count == 1 else "wallets hold" }}
  recoverable {{ issuer_freezable.token }} positions issued by
  {{ issuer.name }}. Each address is independently verifiable on
  {{ primary_chain_explorer_name }} and was confirmed at the timestamp shown in the footer.
</p>
<table class="evidence">
  <thead>
    <tr>
      <th style="width:5em;">Status</th>
      <th>Address</th>
      <th class="amount" style="width:11em;">Balance</th>
      <th class="amount" style="width:9em;">USD value</th>
    </tr>
  </thead>
  <tbody>
    {# v0.27.2 (Jacob 0x52Aa bleed fix, item 1): section 4.1 is the
       per-issuer PRIMARY FREEZE TARGETS table — iterate
       `freezable_holdings` only. Section 4.2 below (Complete
       Holdings Inventory) intentionally uses `holdings` to give LE
       the full picture across all statuses; that section is the
       right place for INVESTIGATE/UNRECOVERABLE/EXCHANGE rows, not
       this one. Without this filter a $46M 1inch-pool INVESTIGATE
       row reads as a primary freeze target alongside a $245K real
       FREEZABLE row — internal contradiction that ships to AUSA.

       v0.20.2 historical note (preserved per-status branches below
       as defense-in-depth): so a future regression that re-
       introduces non-FREEZABLE rows here renders them with the
       correct pill rather than silently mislabeling everything.
    #}
    {% for h in issuer_freezable.freezable_holdings %}
    <tr>
      <td>
        {% if h.status == 'FREEZABLE' %}
        <span class="label-pill" style="color:#2F6B3E;">FREEZABLE</span>
        {% elif h.status == 'INVESTIGATE' %}
        <span class="label-pill" style="color:#7C2D12;">INVESTIGATE</span>
        {% elif h.status == 'UNRECOVERABLE' %}
        <span class="label-pill" style="color:#6B7280;">UNRECOVERABLE</span>
        {% elif h.status == 'EXCHANGE' %}
        <span class="label-pill" style="color:#1E40AF;">EXCHANGE</span>
        {% elif h.status == 'TRANSIT' %}
        <span class="label-pill" style="color:#92400E;">TRANSIT</span>
        {% else %}
        <span class="label-pill" style="color:#6B7280;">{{ h.status or 'UNKNOWN' }}</span>
        {% endif %}
      </td>
      <td class="mono">{% if h.explorer_url %}<a href="{{ h.explorer_url|safe_url }}">{{ h.address }}</a>{% else %}{{ h.address }}{% endif %}</td>
      <td class="amount mono">{{ h.amount }}</td>
      <td class="amount mono">{{ h.usd }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<p class="small">
  <strong>FREEZABLE</strong> positions are
  ({{ issuer_freezable.freezable_count }} addresses,
  {{ issuer_freezable.total_usd_freezable }} total) confirmed-held
  in wallets that have no matching KYC subscription on file with
  {{ issuer.short_name }} — they were received via direct on-chain
  transfer, not via subscription. These are the highest-priority
  targets for an immediate preservation request.
  {% if issuer_freezable.has_investigate %}
  <strong>INVESTIGATE</strong> positions
  ({{ issuer_freezable.investigate_count }} addresses representing
  {{ issuer_freezable.total_usd_suspected }} INVESTIGATE-tier) require KYC verification at
  {{ issuer.short_name }} before status can be confirmed.
  {% endif %}
  Freeze capability assessment: <strong>{{ issuer_freezable.freeze_capability }}</strong>.
</p>
{% endif %}

{# v0.20.3 (render-sim audit): Section 4.2 — complete holdings inventory
   across ALL issuers. Pre-v0.20.3 the LE handoff only showed the single
   issuer passed as `issuer_freezable` (e.g., Midas), so law enforcement
   received an incomplete picture — Circle/Tether/Coinbase holdings and
   Sky Protocol UNRECOVERABLE status were invisible. Now: when the caller
   passes `all_issuers_freezable` (the full freeze_brief.FREEZABLE list),
   the LE renders every issuer's holdings including UNRECOVERABLE entries
   that still matter for asset seizure if the perpetrator is identified. #}
{% if all_issuers_freezable %}
<h2>4.2 Complete Holdings Inventory — All Issuers</h2>
<p>
  The following table lists all identified holdings across every token issuer
  in this case. This includes <strong>FREEZABLE</strong> positions (primary freeze targets),
  <strong>INVESTIGATE</strong> positions (requiring KYC verification before status is
  confirmed), and <strong>UNRECOVERABLE</strong> positions (no issuer-level freeze
  pathway, but relevant for asset seizure if the perpetrator is identified).
</p>
{% for entry in all_issuers_freezable %}
{% if entry.ctx %}
<h3>{{ entry.issuer_name }} — {{ entry.token }}</h3>
<table class="evidence">
  <thead>
    <tr>
      <th style="width:8em;">Status</th>
      <th>Address</th>
      <th class="amount" style="width:13em;">Balance</th>
      <th class="amount" style="width:10em;">USD value</th>
    </tr>
  </thead>
  <tbody>
    {% for h in entry.ctx.holdings %}
    <tr>
      <td>
        {% if h.status == 'FREEZABLE' %}
        <span class="label-pill" style="color:#2F6B3E; font-weight:600;">FREEZABLE</span>
        {% elif h.status == 'INVESTIGATE' %}
        <span class="label-pill" style="color:#7C2D12; font-weight:600;">INVESTIGATE</span>
        {% elif h.status == 'UNRECOVERABLE' %}
        <span class="label-pill" style="color:#6B7280; font-weight:600;">UNRECOVERABLE</span>
        {% elif h.status == 'EXCHANGE' %}
        <span class="label-pill" style="color:#1E40AF; font-weight:600;">EXCHANGE</span>
        {% elif h.status == 'TRANSIT' %}
        <span class="label-pill" style="color:#92400E; font-weight:600;">TRANSIT</span>
        {% else %}
        <span class="label-pill" style="color:#6B7280;">{{ h.status or 'UNKNOWN' }}</span>
        {% endif %}
      </td>
      <td class="mono">{% if h.explorer_url %}<a href="{{ h.explorer_url|safe_url }}">{{ h.address }}</a>{% else %}{{ h.address }}{% endif %}</td>
      <td class="amount mono">{{ h.amount }}</td>
      <td class="amount mono">{{ h.usd }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<p class="small">
  {{ entry.issuer_name }}:
  {% if entry.total_usd and entry.total_usd != '$0' %}{{ entry.total_usd }} freezable{% endif %}
  {% if entry.total_suspected_usd and entry.total_suspected_usd != '$0' %}, {{ entry.total_suspected_usd }} under investigation{% endif %}
  {% if entry.total_excluded_usd and entry.total_excluded_usd != '$0' and (not entry.total_usd or entry.total_usd == '$0') and (not entry.total_suspected_usd or entry.total_suspected_usd == '$0') %}{{ entry.total_excluded_usd }} held (UNRECOVERABLE — no freeze pathway; seizure target if perpetrator identified){% endif %}.
  Freeze capability: <strong>{{ entry.freeze_capability }}</strong>.
</p>
{% endif %}
{% endfor %}
{% endif %}

<h2>5. Identified Wallets</h2>
<table class="evidence">
  <tr>
    <th>Address</th>
    <th>Role</th>
    <th>Type</th>
    <th>Notes</th>
  </tr>
  {% for w in identified_wallets %}
  <tr class="{{ w.row_class }}">
    <td class="mono">{% if w.explorer_url %}<a href="{{ w.explorer_url|safe_url }}">{{ w.address }}</a>{% else %}{{ w.address }}{% endif %}</td>
    <td>{{ w.role }}</td>
    <td>{{ w.type }}</td>
    <td>{{ w.notes }}</td>
  </tr>
  {% endfor %}
</table>

{# v0.22.0 — Section 5.4: Recovery Forecast (per-issuer breakdown).
   Surfaces the scorer's per_issuer rows so law enforcement can see
   the expected-recovery breakdown at a glance: which issuers are
   high-probability, which are pre-learned vs. heuristic, which
   carry historical-receipt discounts. Hidden when the scorer
   produced no per-issuer data (e.g., no FREEZABLE entries). #}
{% if recovery_estimate and recovery_estimate.get('per_issuer') %}
<h2>5.4 Recovery Forecast</h2>
<p class="small">
  Per-issuer expected recovery, sorted by contribution. Each row's
  expected amount is the product of the requested freeze, the
  base prior (learned from prior outcomes or heuristic), and the
  evidence-mode discount applied when the underlying evidence is a
  historical receipt rather than a confirmed current balance.
</p>
<table class="evidence">
  <thead>
    <tr>
      <th>Issuer</th>
      <th>Requested</th>
      <th>Base prior</th>
      <th>Evidence mode</th>
      <th>Effective P(freeze)</th>
      <th>Expected recovery</th>
      <th>Source</th>
    </tr>
  </thead>
  <tbody>
    {% for row in recovery_estimate.get('per_issuer') %}
    <tr>
      <td><strong>{{ row.issuer }}</strong></td>
      <td class="amount">{{ row.requested_usd_human }}</td>
      <td>
        {{ row.base_prior_pct }}
        {% if row.get('capability_override_applied') %}
        <br/><span class="small secondary">overridden to {{ row.get('base_prior_post_override_pct') }} by reported freeze_capability</span>
        {% endif %}
      </td>
      <td>
        {% if row.evidence_mode == 'historical_only' %}
        historical receipt (×{{ row.evidence_discount_pct }})
        {% elif row.evidence_mode == 'mixed' %}
        mixed (×{{ row.evidence_discount_pct }})
        {% else %}
        current balance
        {% endif %}
      </td>
      <td><strong>{{ row.effective_prior_pct }}</strong></td>
      <td class="amount">{{ row.expected_recovered_usd_human }}</td>
      <td class="small">
        {% if row.is_learned_prior %}<em>learned</em>{% else %}heuristic{% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<p class="small">
  <strong>Source key.</strong> <em>learned</em>: per-issuer prior
  computed from real Recupero freeze-outcome history (≥20 letters
  required for inclusion); <em>heuristic</em>: hand-coded prior from
  the issuer-cooperation table (insufficient outcome history for a
  learned model). Both are jurisdiction-adjusted and may be further
  reduced by sanctions-overlay or concentration adjustments — see
  Recovery Drivers below.
</p>
{% endif %}

{# v0.22.0 — Recovery Drivers list. Independently gated so it
   renders when the scorer produces drivers even if no per-issuer
   breakdown exists (e.g., a case where every freezable issuer
   has total_usd == $0 but the scorer still emits a jurisdiction
   driver). Surfaces the scorer's RecoveryDriver entries as
   "What's helping" / "What's hurting" to give the operator a
   defensible decomposition of the headline recovery number. #}
{% if recovery_estimate and recovery_estimate.get('drivers') %}
<h3>Recovery drivers</h3>
<table class="evidence">
  <thead>
    <tr>
      <th>Factor</th>
      <th>Direction</th>
      <th>Description</th>
    </tr>
  </thead>
  <tbody>
    {% for d in recovery_estimate.get('drivers') %}
    <tr>
      <td><strong>{{ d.factor }}</strong></td>
      <td>
        {% if d.direction == 'positive' %}
        <span style="color:#166534;font-weight:600">supports</span>
        {% else %}
        <span style="color:#991b1b;font-weight:600">reduces</span>
        {% endif %}
      </td>
      <td class="small">{{ d.description }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{# v0.22.0 — Net-to-victim ROI block. Independently gated so it
   renders even when per_issuer is empty. Lawyers / AUSAs /
   financial-recovery counsel weigh case priority on the net dollars
   actually reaching the victim after fees, not the gross recovery
   figure. This block makes that conversion explicit.

   v0.22.1 (audit-fix C2 CRITICAL + H1 + H3):
     * Negative net → label reframes as "Estimated net cost if engaged"
       (the headline value is still rendered, but the label tells the
       truth about its sign — pre-v0.22.1 we labeled negative
       dollars as "net recovery", which read as a bug to anyone
       skimming).
     * "95% confidence interval" → "90% confidence interval" to match
       the actual Beta posterior level=0.90 the scorer uses.
     * Probability rows use `is not none` so a true 0.0 ("no chance")
       still surfaces — most informative signal on a reject case.
#}
{% if recovery_estimate and recovery_estimate.get('expected_net_to_victim_usd') %}
{% set _net_raw_le = recovery_estimate.get('expected_net_to_victim_usd') %}
{% set _net_negative_le = _net_raw_le.startswith('$-') %}
<h3>Net to victim</h3>
<p class="small">
  After Recupero's diagnostic + engagement fees and any
  contingency cut, the projected dollars reaching the victim's
  account are:
</p>
<table class="evidence">
  <tr>
    <th>
      {% if _net_negative_le %}Estimated net cost if engaged (mid){% else %}Projected net recovery (mid){% endif %}
    </th>
    <td class="amount"><strong{% if _net_negative_le %} style="color:#7f1d1d"{% endif %}>{{ _net_raw_le }}</strong></td>
  </tr>
  {% if recovery_estimate.get('expected_net_low_usd') and recovery_estimate.get('expected_net_high_usd') %}
  <tr>
    <th>90% confidence interval</th>
    <td class="amount">
      {{ recovery_estimate.get('expected_net_low_usd') }}
      &nbsp;–&nbsp;
      {{ recovery_estimate.get('expected_net_high_usd') }}
    </td>
  </tr>
  {% endif %}
  {% if recovery_estimate.get('expected_recupero_revenue_usd') %}
  <tr>
    <th>Recupero fees (engagement + contingency, projected)</th>
    <td class="amount small">{{ recovery_estimate.get('expected_recupero_revenue_usd') }}</td>
  </tr>
  {% endif %}
  {% if recovery_estimate.get('probability_pays_back_engagement_180d') is not none %}
  <tr>
    <th>Probability case pays back engagement fee within 180d</th>
    <td class="amount">
      {{ "%.0f%%"|format(recovery_estimate.get('probability_pays_back_engagement_180d') * 100) }}
    </td>
  </tr>
  {% endif %}
</table>
{% endif %}

{# v0.21.0 — Section 5.5: Live Filing Status.
   When `live_status` is provided (re-render after letters have been
   mailed), shows real-time outcomes per freeze letter + monitoring
   counters. On the first render (immediately after emit_brief, no
   letters yet) renders the pending-state branch. #}
<h2>5.5 Live Filing Status</h2>
{% if live_status and not live_status.is_empty %}
<p class="small">
  Real-time status of every freeze letter dispatched for this case,
  joined to the live wallet-monitoring subscriptions. Reflects the
